+    @ConformanceTest(name = "HumanEntity permission delegates are isolated and expire timed attachments", category = TestCategory.PERMISSIONS)
+    public void testHumanEntityPermissionDelegation() throws InterruptedException {
+        PatchBukkitHumanEntity first = new PatchBukkitHumanEntity(
+            java.util.UUID.randomUUID(), "permission-first"
+        );
+        PatchBukkitHumanEntity second = new PatchBukkitHumanEntity(
+            java.util.UUID.randomUUID(), "permission-second"
+        );
+        PermissionAttachment immediate = first.addAttachment(plugin, "patchbukkit.test.isolated", true);
+        PermissionAttachment timed = first.addAttachment(plugin, "patchbukkit.test.timed", true, 1);
+        CountDownLatch timedRemoval = new CountDownLatch(1);
+        timed.setRemovalCallback(attachment -> timedRemoval.countDown());
+        try {
+            assertTrue(first.hasPermission("patchbukkit.test.isolated"), "attachment should delegate to player perm");
+            assertTrue(!second.hasPermission("patchbukkit.test.isolated"), "player permission delegates must be isolated");
+            assertTrue(
+                first.getEffectivePermissions().stream().anyMatch(
+                    value -> value.getPermission().equals("patchbukkit.test.isolated") && value.getValue()
+                ),
+                "effective permissions should reflect delegated attachments"
+            );
+            assertTrue(first.hasPermission("patchbukkit.test.timed"), "timed attachment should apply first");
+            assertTrue(
+                timedRemoval.await(2, TimeUnit.SECONDS),
+                "timed attachment removal callback should run"
+            );
+            assertTrue(!first.hasPermission("patchbukkit.test.timed"), "timed attachment should expire after its tick delay");
+        } finally {
+            first.removeAttachment(immediate);
+        }
+    }
 
