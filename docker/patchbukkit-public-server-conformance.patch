+    @ConformanceTest(name = "Metadata is shared by stable entity, block, and world identities", category = TestCategory.SERVER)
+    public void testRuntimeMetadataOwnershipAndCleanup() {
+        PluginLoader failingLoader = (PluginLoader) Proxy.newProxyInstance(
+            PluginLoader.class.getClassLoader(),
+            new Class<?>[] { PluginLoader.class },
+            (proxy, method, args) -> {
+                if (method.getName().equals("disablePlugin")) {
+                    throw new IllegalStateException("intentional metadata cleanup test failure");
+                }
+                return null;
+            }
+        );
+        Plugin secondaryOwner = (Plugin) Proxy.newProxyInstance(
+            Plugin.class.getClassLoader(),
+            new Class<?>[] { Plugin.class },
+            (proxy, method, args) -> switch (method.getName()) {
+                case "getName" -> "PatchBukkitMetadataSecondaryOwner";
+                case "getLogger" -> Logger.getLogger("PatchBukkitMetadataSecondaryOwner");
+                case "getPluginLoader" -> failingLoader;
+                case "isEnabled" -> true;
+                case "equals" -> proxy == args[0];
+                case "hashCode" -> System.identityHashCode(proxy);
+                default -> null;
+            }
+        );
+        PatchBukkitHumanEntity firstPlayer = new PatchBukkitHumanEntity(
+            java.util.UUID.randomUUID(), "metadata-first"
+        );
+        PatchBukkitHumanEntity samePlayer = new PatchBukkitHumanEntity(
+            firstPlayer.getUniqueId(), "metadata-second-wrapper"
+        );
+        World world = Bukkit.getWorlds().get(0);
+        Block firstBlock = world.getBlockAt(10, world.getMinHeight() + 1, 10);
+        Block secondBlock = world.getBlockAt(10, world.getMinHeight() + 1, 10);
+
+        firstPlayer.setMetadata("owner-check", new FixedMetadataValue(plugin, "first"));
+        firstPlayer.setMetadata("owner-check", new FixedMetadataValue(secondaryOwner, "second"));
+        firstBlock.setMetadata("wrapper-check", new FixedMetadataValue(plugin, "block"));
+        world.setMetadata("world-check", new FixedMetadataValue(plugin, "world"));
+        try {
+            assertTrue(samePlayer.hasMetadata("owner-check"), "entity metadata should be shared by UUID");
+            assertTrue(
+                samePlayer.getMetadata("owner-check").size() == 2,
+                "different plugin owners should retain independent values"
+            );
+            firstPlayer.removeMetadata("owner-check", plugin);
+            assertTrue(
+                samePlayer.getMetadata("owner-check").size() == 1,
+                "removing one owner must preserve the other owner's metadata"
+            );
+            assertTrue(secondBlock.hasMetadata("wrapper-check"), "block metadata should survive a fresh wrapper");
+            assertTrue(world.hasMetadata("world-check"), "world metadata should be available");
+
+            boolean disableFailed = false;
+            try {
+                Bukkit.getPluginManager().disablePlugin(secondaryOwner);
+            } catch (IllegalStateException expected) {
+                disableFailed = true;
+            }
+            assertTrue(disableFailed, "test plugin loader should exercise exceptional disable cleanup");
+            assertTrue(!samePlayer.hasMetadata("owner-check"), "plugin cleanup should remove owned metadata");
+        } finally {
+            firstPlayer.removeMetadata("owner-check", plugin);
+            firstPlayer.removeMetadata("owner-check", secondaryOwner);
+            firstBlock.removeMetadata("wrapper-check", plugin);
+            world.removeMetadata("world-check", plugin);
+        }
+    }
