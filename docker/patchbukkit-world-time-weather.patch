+    @ConformanceTest(name = "World time and weather round-trip through Pumpkin", category = TestCategory.SERVER)
+    public void testWorldTimeAndWeather() {
+        World world = Bukkit.getWorlds().get(0);
+        long fullTime = world.getFullTime();
+        boolean storm = world.hasStorm();
+        boolean thundering = world.isThundering();
+        int weatherDuration = world.getWeatherDuration();
+        int thunderDuration = world.getThunderDuration();
+        int clearWeatherDuration = world.getClearWeatherDuration();
+
+        try {
+            world.setFullTime(fullTime + 20);
+            long observedFullTime = world.getFullTime();
+            assertTrue(
+                observedFullTime >= fullTime + 20 && observedFullTime <= fullTime + 25,
+                "full time should round-trip while the world keeps ticking"
+            );
+            assertTrue(world.getTime() >= 0 && world.getTime() < 24000, "day time should be normalized");
+            assertTrue(world.getGameTime() >= 0, "game time should be available");
+
+            world.setStorm(!storm);
+            assertTrue(world.hasStorm() != storm, "storm state should round-trip");
+            world.setWeatherDuration(200);
+            int observedWeatherDuration = world.getWeatherDuration();
+            assertTrue(
+                observedWeatherDuration >= 195 && observedWeatherDuration <= 200,
+                "weather duration should round-trip while the world keeps ticking"
+            );
+
+            world.setThundering(!thundering);
+            assertTrue(world.isThundering() != thundering, "thunder state should round-trip");
+            world.setThunderDuration(300);
+            int observedThunderDuration = world.getThunderDuration();
+            assertTrue(
+                observedThunderDuration >= 295 && observedThunderDuration <= 300,
+                "thunder duration should round-trip while the world keeps ticking"
+            );
+
+            world.setClearWeatherDuration(400);
+            int observedClearWeatherDuration = world.getClearWeatherDuration();
+            assertTrue(
+                observedClearWeatherDuration >= 395 && observedClearWeatherDuration <= 400,
+                "clear-weather duration should round-trip while the world keeps ticking"
+            );
+        } finally {
+            world.setFullTime(fullTime);
+            world.setStorm(storm);
+            world.setWeatherDuration(weatherDuration);
+            world.setThundering(thundering);
+            world.setThunderDuration(thunderDuration);
+            world.setClearWeatherDuration(clearWeatherDuration);
+        }
+    }
+
+    @ConformanceTest(name = "World weather setters fire cancellable Bukkit events", category = TestCategory.SERVER)
+    public void testWorldWeatherCancellation() {
+        World world = Bukkit.getWorlds().get(0);
+        boolean originalStorm = world.hasStorm();
+        boolean originalThunder = world.isThundering();
+        boolean replacementStorm = !originalStorm;
+        boolean replacementThunder = !originalThunder;
+        AtomicBoolean weatherObserved = new AtomicBoolean();
+        AtomicBoolean thunderObserved = new AtomicBoolean();
+
+        Listener listener = new Listener() {
+            @EventHandler
+            public void onWeatherChange(WeatherChangeEvent event) {
+                if (event.getWorld() == world
+                    && event.toWeatherState() == replacementStorm) {
+                    weatherObserved.set(true);
+                    event.setCancelled(true);
+                }
+            }
+
+            @EventHandler
+            public void onThunderChange(ThunderChangeEvent event) {
+                if (event.getWorld() == world
+                    && event.toThunderState() == replacementThunder) {
+                    thunderObserved.set(true);
+                    event.setCancelled(true);
+                }
+            }
+        };
+
+        Bukkit.getPluginManager().registerEvents(listener, plugin);
+        try {
+            world.setStorm(replacementStorm);
+            assertTrue(weatherObserved.get(), "WeatherChangeEvent should be delivered");
+            assertTrue(
+                world.hasStorm() == originalStorm,
+                "cancelled WeatherChangeEvent should preserve rain state"
+            );
+
+            world.setThundering(replacementThunder);
+            assertTrue(thunderObserved.get(), "ThunderChangeEvent should be delivered");
+            assertTrue(
+                world.isThundering() == originalThunder,
+                "cancelled ThunderChangeEvent should preserve thunder state"
+            );
+        } finally {
+            HandlerList.unregisterAll(listener);
+            world.setStorm(originalStorm);
+            world.setThundering(originalThunder);
+        }
+    }
