diff --git a/rust/src/java/native_callbacks/world.rs b/rust/src/java/native_callbacks/world.rs
new file mode 100644
index 0000000000000000000000000000000000000000..021e4b59a4aee72741080aed1444cc2d4bc5bca2
--- /dev/null
+++ b/rust/src/java/native_callbacks/world.rs
@@ -0,0 +1,121 @@
+use std::sync::Arc;
+
+use pumpkin::world::World;
+
+use crate::{
+    java::native_callbacks::CALLBACK_CONTEXT,
+    proto::patchbukkit::world::{
+        UpdateWorldStateRequest, UpdateWorldStateResponse, WorldState, WorldStateRequest,
+    },
+};
+
+fn find_world(world_uuid: &str) -> Option<Arc<World>> {
+    let context = CALLBACK_CONTEXT.get()?;
+    let uuid = uuid::Uuid::parse_str(world_uuid).ok()?;
+    context
+        .plugin_context
+        .server
+        .worlds
+        .load()
+        .iter()
+        .find(|world| world.uuid == uuid)
+        .cloned()
+}
+
+async fn snapshot(world: &World) -> WorldState {
+    let level_time = world.level_time.lock().await;
+    let full_time = level_time.time_of_day;
+    let game_time = level_time.world_age;
+    drop(level_time);
+
+    let weather = world.weather.lock().await;
+    WorldState {
+        full_time,
+        game_time,
+        raining: weather.raining,
+        rain_time: weather.rain_time,
+        thundering: weather.thundering,
+        thunder_time: weather.thunder_time,
+        clear_weather_time: weather.clear_weather_time,
+    }
+}
+
+pub fn ffi_native_bridge_get_world_state_impl(request: WorldStateRequest) -> Option<WorldState> {
+    let context = CALLBACK_CONTEXT.get()?;
+    let world = find_world(&request.world_uuid?.value)?;
+
+    Some(tokio::task::block_in_place(|| {
+        context.runtime.block_on(snapshot(&world))
+    }))
+}
+
+pub fn ffi_native_bridge_update_world_state_impl(
+    request: UpdateWorldStateRequest,
+) -> Option<UpdateWorldStateResponse> {
+    let context = CALLBACK_CONTEXT.get()?;
+    let world = find_world(&request.world_uuid?.value)?;
+
+    if request.rain_time.is_some_and(|value| value < 0)
+        || request.thunder_time.is_some_and(|value| value < 0)
+        || request.clear_weather_time.is_some_and(|value| value < 0)
+    {
+        return Some(UpdateWorldStateResponse {
+            success: false,
+            state: None,
+        });
+    }
+
+    Some(tokio::task::block_in_place(|| {
+        context.runtime.block_on(async {
+            if let Some(full_time) = request.full_time {
+                world.set_time_of_day(full_time).await;
+            }
+
+            if request.raining.is_some()
+                || request.rain_time.is_some()
+                || request.thundering.is_some()
+                || request.thunder_time.is_some()
+                || request.clear_weather_time.is_some()
+            {
+                let (
+                    current_raining,
+                    current_rain_time,
+                    current_thundering,
+                    current_thunder_time,
+                    current_clear_weather_time,
+                ) = {
+                    let weather = world.weather.lock().await;
+                    (
+                        weather.raining,
+                        weather.rain_time,
+                        weather.thundering,
+                        weather.thunder_time,
+                        weather.clear_weather_time,
+                    )
+                };
+                let raining = request.raining.unwrap_or(current_raining);
+                let rain_time = request.rain_time.unwrap_or(current_rain_time);
+                let thundering = request.thundering.unwrap_or(current_thundering);
+                let thunder_time = request.thunder_time.unwrap_or(current_thunder_time);
+                let clear_weather_time = request
+                    .clear_weather_time
+                    .unwrap_or(current_clear_weather_time);
+
+                world
+                    .set_weather_parameters_after_event(
+                        clear_weather_time,
+                        rain_time,
+                        thunder_time,
+                        raining,
+                        thundering,
+                    )
+                    .await;
+            }
+
+            UpdateWorldStateResponse {
+                success: true,
+                state: Some(snapshot(&world).await),
+            }
+        })
+    }))
+}
