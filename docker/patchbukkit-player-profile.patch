+package org.patchbukkit.profile;
+
+import com.destroystokyo.paper.profile.PlayerProfile;
+import com.destroystokyo.paper.profile.ProfileProperty;
+import java.net.URL;
+import java.util.Collection;
+import java.util.LinkedHashMap;
+import java.util.LinkedHashSet;
+import java.util.Map;
+import java.util.Objects;
+import java.util.Set;
+import java.util.UUID;
+import java.util.concurrent.CompletableFuture;
+import org.bukkit.profile.PlayerTextures;
+import org.jetbrains.annotations.NotNull;
+import org.jetbrains.annotations.Nullable;
+
+/**
+ * Lightweight profile used while a client is still in the pre-login phase.
+ *
+ * <p>PatchBukkit does not own Mojang's profile cache yet, so completion methods
+ * report whether the supplied identity is already complete instead of doing
+ * network I/O.</p>
+ */
+public final class PatchBukkitPlayerProfile implements PlayerProfile {
+    private @Nullable UUID id;
+    private @Nullable String name;
+    private PlayerTextures textures;
+    private final Set<ProfileProperty> properties;
+
+    public PatchBukkitPlayerProfile(@Nullable UUID id, @Nullable String name) {
+        if (id == null && (name == null || name.isBlank())) {
+            throw new IllegalArgumentException("A player profile requires a UUID or name");
+        }
+        this.id = id;
+        this.name = name;
+        this.textures = new EmptyPlayerTextures();
+        this.properties = new LinkedHashSet<>();
+    }
+
+    private PatchBukkitPlayerProfile(PatchBukkitPlayerProfile source) {
+        this.id = source.id;
+        this.name = source.name;
+        this.textures = source.textures instanceof EmptyPlayerTextures empty
+            ? new EmptyPlayerTextures(empty)
+            : source.textures;
+        this.properties = new LinkedHashSet<>(source.properties);
+    }
+
+    @Override
+    public @Nullable String getName() {
+        return this.name;
+    }
+
+    @Override
+    public @Nullable String setName(@Nullable String name) {
+        String previous = this.name;
+        this.name = name;
+        return previous;
+    }
+
+    @Override
+    public @Nullable UUID getId() {
+        return this.id;
+    }
+
+    @Override
+    public @Nullable UUID setId(@Nullable UUID id) {
+        UUID previous = this.id;
+        this.id = id;
+        return previous;
+    }
+
+    @Override
+    public @Nullable UUID getUniqueId() {
+        return this.id;
+    }
+
+    @Override
+    public @NotNull PlayerTextures getTextures() {
+        return this.textures;
+    }
+
+    @Override
+    public void setTextures(@Nullable PlayerTextures textures) {
+        this.textures = textures == null ? new EmptyPlayerTextures() : textures;
+    }
+
+    @Override
+    public @NotNull Set<ProfileProperty> getProperties() {
+        return this.properties;
+    }
+
+    @Override
+    public boolean hasProperty(@NotNull String property) {
+        return this.properties.stream().anyMatch(value -> value.getName().equals(property));
+    }
+
+    @Override
+    public void setProperty(@NotNull ProfileProperty property) {
+        removeProperty(property.getName());
+        this.properties.add(property);
+    }
+
+    @Override
+    public void setProperties(@NotNull Collection<ProfileProperty> properties) {
+        properties.forEach(this::setProperty);
+    }
+
+    @Override
+    public boolean removeProperty(@NotNull String property) {
+        return this.properties.removeIf(value -> value.getName().equals(property));
+    }
+
+    @Override
+    public void clearProperties() {
+        this.properties.clear();
+    }
+
+    @Override
+    public boolean isComplete() {
+        return this.id != null && this.name != null && !this.name.isBlank();
+    }
+
+    @Override
+    public boolean completeFromCache() {
+        return isComplete();
+    }
+
+    @Override
+    public boolean completeFromCache(boolean onlineMode) {
+        return isComplete();
+    }
+
+    @Override
+    public boolean completeFromCache(boolean onlineMode, boolean lookupUuid) {
+        return isComplete();
+    }
+
+    @Override
+    public boolean complete(boolean textures) {
+        return isComplete();
+    }
+
+    @Override
+    public boolean complete(boolean textures, boolean onlineMode) {
+        return isComplete();
+    }
+
+    @Override
+    public @NotNull CompletableFuture<PlayerProfile> update() {
+        return CompletableFuture.completedFuture(clone());
+    }
+
+    @Override
+    public @NotNull PatchBukkitPlayerProfile clone() {
+        return new PatchBukkitPlayerProfile(this);
+    }
+
+    @Override
+    public @NotNull Map<String, Object> serialize() {
+        Map<String, Object> result = new LinkedHashMap<>();
+        if (this.id != null) {
+            result.put("uniqueId", this.id.toString());
+        }
+        if (this.name != null) {
+            result.put("name", this.name);
+        }
+        return result;
+    }
+
+    @Override
+    public boolean equals(Object other) {
+        if (this == other) return true;
+        if (!(other instanceof PatchBukkitPlayerProfile profile)) return false;
+        return Objects.equals(this.id, profile.id)
+            && Objects.equals(this.name, profile.name)
+            && this.properties.equals(profile.properties);
+    }
+
+    @Override
+    public int hashCode() {
+        return Objects.hash(this.id, this.name, this.properties);
+    }
+
+    private static final class EmptyPlayerTextures implements PlayerTextures {
+        private @Nullable URL skin;
+        private SkinModel skinModel = SkinModel.CLASSIC;
+        private @Nullable URL cape;
+
+        private EmptyPlayerTextures() {
+        }
+
+        private EmptyPlayerTextures(EmptyPlayerTextures source) {
+            this.skin = source.skin;
+            this.skinModel = source.skinModel;
+            this.cape = source.cape;
+        }
+
+        @Override
+        public boolean isEmpty() {
+            return this.skin == null && this.cape == null;
+        }
+
+        @Override
+        public void clear() {
+            this.skin = null;
+            this.skinModel = SkinModel.CLASSIC;
+            this.cape = null;
+        }
+
+        @Override
+        public @Nullable URL getSkin() {
+            return this.skin;
+        }
+
+        @Override
+        public void setSkin(@Nullable URL skinUrl) {
+            setSkin(skinUrl, SkinModel.CLASSIC);
+        }
+
+        @Override
+        public void setSkin(@Nullable URL skinUrl, @Nullable SkinModel skinModel) {
+            this.skin = skinUrl;
+            this.skinModel = skinModel == null ? SkinModel.CLASSIC : skinModel;
+        }
+
+        @Override
+        public @NotNull SkinModel getSkinModel() {
+            return this.skinModel;
+        }
+
+        @Override
+        public @Nullable URL getCape() {
+            return this.cape;
+        }
+
+        @Override
+        public void setCape(@Nullable URL capeUrl) {
+            this.cape = capeUrl;
+        }
+
+        @Override
+        public long getTimestamp() {
+            return 0L;
+        }
+
+        @Override
+        public boolean isSigned() {
+            return false;
+        }
+    }
+}
