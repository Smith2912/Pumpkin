+    static String nativeSubscriptionType(@NotNull Class<? extends Event> event) {
+        // Pumpkin exposes both Bukkit interaction variants through one native
+        // event. A single canonical subscription prevents interact-at actions
+        // from being bridged twice when plugins listen to both HandlerLists.
+        if (PlayerInteractAtEntityEvent.class.isAssignableFrom(event)) {
