+package org.patchbukkit.entity;
+
+import java.lang.reflect.InvocationHandler;
+import java.lang.reflect.Method;
+import java.lang.reflect.Proxy;
+import java.util.Collections;
+import java.util.Locale;
+import java.util.UUID;
+
+import org.bukkit.Bukkit;
+import org.bukkit.Location;
+import org.bukkit.World;
+import org.bukkit.entity.ArmorStand;
+import org.bukkit.entity.EnderCrystal;
+import org.bukkit.entity.Entity;
+import org.bukkit.entity.EntityType;
+import org.bukkit.entity.ItemFrame;
+import org.bukkit.entity.Player;
+import org.bukkit.metadata.MetadataValue;
+import org.bukkit.plugin.Plugin;
+import org.bukkit.util.Vector;
+import org.jetbrains.annotations.NotNull;
+import org.patchbukkit.metadata.PatchBukkitMetadataStore;
+
+import patchbukkit.events.EntityReference;
+
+/**
+ * Immutable Bukkit entity view used only while dispatching a native interaction.
+ *
+ * <p>The client supplied an entity id, but the bridge captures the target before
+ * entering Java. This prevents listeners from observing a different entity if that
+ * id is reused while the synchronous event is in flight.</p>
+ */
+public final class PatchBukkitEntitySnapshot {
+    private PatchBukkitEntitySnapshot() {
+    }
+
+    public static Entity create(@NotNull EntityReference reference) {
+        if (!reference.hasUuid() || !reference.hasLocation() || !reference.getLocation().hasWorld()
+            || !reference.getLocation().hasPosition()
+            || !reference.getLocation().getWorld().hasUuid()) {
+            throw new IllegalArgumentException("entity interaction snapshot is incomplete");
+        }
+
+        final UUID uuid = UUID.fromString(reference.getUuid().getValue());
+        final String resourceName = reference.getEntityType();
+        final String typeName = resourceName.startsWith("minecraft:")
+            ? resourceName.substring("minecraft:".length())
+            : resourceName;
+        final EntityType entityType;
+        try {
+            entityType = EntityType.valueOf(typeName.toUpperCase(Locale.ROOT));
+        } catch (IllegalArgumentException exception) {
+            throw new IllegalArgumentException("unsupported entity interaction type " + resourceName, exception);
+        }
+
+        Class<? extends Entity> interfaceType = switch (entityType) {
+            case PLAYER -> Player.class;
+            case ITEM_FRAME, GLOW_ITEM_FRAME -> ItemFrame.class;
+            case ARMOR_STAND -> ArmorStand.class;
+            case END_CRYSTAL -> EnderCrystal.class;
+            default -> throw new IllegalArgumentException(
+                "unsupported entity interaction type " + resourceName
+            );
+        };
+
+        World world = Bukkit.getWorld(UUID.fromString(reference.getLocation().getWorld().getUuid().getValue()));
+        if (world == null) {
+            throw new IllegalArgumentException("interaction target world is unavailable");
+        }
+        Location location = new Location(
+            world,
+            reference.getLocation().getPosition().getX(),
+            reference.getLocation().getPosition().getY(),
+            reference.getLocation().getPosition().getZ(),
+            reference.getLocation().getYaw(),
+            reference.getLocation().getPitch()
+        );
+
+        InvocationHandler handler = new SnapshotHandler(
+            uuid,
+            reference.getEntityId(),
+            entityType,
+            location
+        );
+        return (Entity) Proxy.newProxyInstance(
+            PatchBukkitEntitySnapshot.class.getClassLoader(),
+            new Class<?>[] { interfaceType },
+            handler
+        );
+    }
+
+    private record SnapshotHandler(
+        UUID uuid,
+        int entityId,
+        EntityType entityType,
+        Location location
+    ) implements InvocationHandler {
+        @Override
+        public Object invoke(Object proxy, Method method, Object[] args) {
+            return switch (method.getName()) {
+                case "getUniqueId" -> uuid;
+                case "getEntityId" -> entityId;
+                case "getType" -> entityType;
+                case "getWorld" -> location.getWorld();
+                case "getLocation" -> copyLocation(args);
+                case "getName" -> entityType.getKey().toString();
+                case "getServer" -> Bukkit.getServer();
+                case "isValid" -> true;
+                case "isDead" -> false;
+                case "isPersistent" -> true;
+                case "getNearbyEntities", "getPassengers" -> Collections.emptyList();
+                case "getTrackedBy", "getScoreboardTags" -> Collections.emptySet();
+                case "isEmpty" -> true;
+                case "getPassenger", "getVehicle", "getCustomName", "getLastDamageCause" -> null;
+                case "getVelocity" -> new Vector();
+                case "hasMetadata" -> PatchBukkitMetadataStore.has(
+                    PatchBukkitMetadataStore.entity(uuid),
+                    (String) args[0]
+                );
+                case "getMetadata" -> PatchBukkitMetadataStore.get(
+                    PatchBukkitMetadataStore.entity(uuid),
+                    (String) args[0]
+                );
+                case "setMetadata" -> setMetadata((String) args[0], (MetadataValue) args[1]);
+                case "removeMetadata" -> removeMetadata((String) args[0], (Plugin) args[1]);
+                case "equals" -> proxy == args[0];
+                case "hashCode" -> uuid.hashCode();
+                case "toString" -> "PatchBukkitEntitySnapshot[" + entityType + "," + uuid + "]";
+                default -> throw new UnsupportedOperationException(
+                    "PatchBukkit entity interaction snapshot does not implement " + method.getName()
+                );
+            };
+        }
+
+        private Object setMetadata(String key, MetadataValue value) {
+            PatchBukkitMetadataStore.set(PatchBukkitMetadataStore.entity(uuid), key, value);
+            return null;
+        }
+
+        private Object removeMetadata(String key, Plugin owner) {
+            PatchBukkitMetadataStore.remove(PatchBukkitMetadataStore.entity(uuid), key, owner);
+            return null;
+        }
+
+        private Location copyLocation(Object[] args) {
+            Location copy = location.clone();
+            if (args != null && args.length == 1 && args[0] instanceof Location target) {
+                target.setWorld(copy.getWorld());
+                target.set(copy.getX(), copy.getY(), copy.getZ());
+                target.setYaw(copy.getYaw());
+                target.setPitch(copy.getPitch());
+                return target;
+            }
+            return copy;
+        }
+    }
+}
