@@ -0,0 +1,34 @@
+package org.patchbukkit.events;
+
+import org.bukkit.event.player.PlayerInteractAtEntityEvent;
+import org.bukkit.event.player.PlayerInteractEntityEvent;
+import org.bukkit.event.player.PlayerInteractEvent;
+
+public final class PatchBukkitEventManagerConformance {
+
+    private PatchBukkitEventManagerConformance() {
+    }
+
+    public static void main(String[] args) {
+        String canonicalType = PlayerInteractEntityEvent.class.getName();
+
+        requireEqual(
+            canonicalType,
+            PatchBukkitEventManager.nativeSubscriptionType(PlayerInteractEntityEvent.class)
+        );
+        requireEqual(
+            canonicalType,
+            PatchBukkitEventManager.nativeSubscriptionType(PlayerInteractAtEntityEvent.class)
+        );
+        requireEqual(
+            PlayerInteractEvent.class.getName(),
+            PatchBukkitEventManager.nativeSubscriptionType(PlayerInteractEvent.class)
+        );
+    }
+
+    private static void requireEqual(String expected, String actual) {
+        if (!expected.equals(actual)) {
+            throw new AssertionError("Expected " + expected + " but got " + actual);
+        }
+    }
+}
