+                    }),
+                    target: Some(entity_reference(&self.target)),
+                    interaction: interaction.to_owned(),
+                    hand: bukkit_hand_name(hand).to_owned(),
+                    click_position: self.target_position.as_ref().map(|position| Vec3 {
+                        x: position.x,
+                        y: position.y,
+                        z: position.z,
+                    }),
+                })),
+            },
+            context: EventContext {
+                server,
+                player: Some(self.player.clone()),
+            },
+        }
+    }
+
+    fn apply_modifications(&mut self, server: &Arc<Server>, data: Data) -> Option<()> {
+        let Data::PlayerInteractEntity(event) = data else {
+            return None;
+        };
+        let player_uuid = uuid::Uuid::parse_str(&event.player_uuid?.value).ok()?;
+        if player_uuid != self.player.gameprofile.id {
+            return None;
+        }
+        server.get_player_by_uuid(player_uuid)?;
+
+        let expected = self.target.get_entity();
+        let actual = event.target?;
+        let target_uuid = uuid::Uuid::parse_str(&actual.uuid?.value).ok()?;
+        if target_uuid != expected.entity_uuid
+            || actual.entity_id != expected.entity_id
+            || actual.entity_type != format!("minecraft:{}", expected.entity_type.resource_name)
+            || event.interaction != bukkit_entity_interaction(&self.action)?
+            || event.hand != bukkit_hand_name(self.hand?)
+            || !same_position(self.target_position.as_ref(), event.click_position.as_ref())
+        {
+            return None;
+        }
+        Some(())
+    }
+
+    fn should_forward(&self) -> bool {
+        let target = self.target.get_entity();
+        if bukkit_entity_interaction(&self.action).is_none() {
+            return false;
+        }
+        if !is_supported_interact_entity(target.entity_type.resource_name) {
+            tracing::warn!(
+                entity_type = target.entity_type.resource_name,
+                "PatchBukkit does not bridge this entity-interaction target type"
+            );
+            return false;
+        }
+        true
+    }
+}
