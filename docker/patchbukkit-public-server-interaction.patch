+const fn bukkit_entity_interaction(action: &ActionType) -> Option<&'static str> {
+    match action {
+        ActionType::Interact => Some("INTERACT"),
+        ActionType::InteractAt => Some("INTERACT_AT"),
+        // ATTACK belongs to Bukkit's damage-event pipeline. Forwarding it as an
+        // interact event would both be incorrect and allow a cancellation to
+        // suppress combat through the wrong API.
+        ActionType::Attack => None,
+    }
+}
+
+const fn bukkit_hand_name(hand: Hand) -> &'static str {
+    match hand {
+        Hand::Right => "HAND",
+        Hand::Left => "OFF_HAND",
+    }
+}
+
+fn is_supported_interact_entity(resource_name: &str) -> bool {
+    matches!(
+        resource_name,
+        "player" | "item_frame" | "glow_item_frame" | "armor_stand" | "end_crystal"
+    )
+}
+
+fn entity_reference(target: &Arc<dyn pumpkin::entity::EntityBase>) -> EntityReference {
+    let entity = target.get_entity();
+    let world = entity.world.load_full();
+    EntityReference {
+        uuid: Some(Uuid {
+            value: entity.entity_uuid.to_string(),
+        }),
+        entity_id: entity.entity_id,
+        entity_type: format!("minecraft:{}", entity.entity_type.resource_name),
+        location: Some(location_reference(
+            world.uuid,
+            entity.pos.load(),
+            entity.yaw.load(),
+            entity.pitch.load(),
+        )),
+    }
+}
+
+fn same_position(
+    expected: Option<&pumpkin_util::math::vector3::Vector3<f64>>,
+    actual: Option<&Vec3>,
+) -> bool {
+    match (expected, actual) {
+        (None, None) => true,
+        (Some(expected), Some(actual)) => {
+            expected.x.to_bits() == actual.x.to_bits()
+                && expected.y.to_bits() == actual.y.to_bits()
+                && expected.z.to_bits() == actual.z.to_bits()
+        }
+        _ => false,
+    }
+}
