+                yield PatchBukkitItemMeta.copyFor(meta, material);
+            }
+            case "getDefaultLeatherColor" -> Color.fromRGB(0xA06540);
+            case "createItemStack" -> createItemStack((String) args[0]);
+            case "displayName" -> {
+                ItemStack item = (ItemStack) args[0];
+                ItemMeta meta = item.getItemMeta();
+                yield meta.hasDisplayName()
+                    ? meta.displayName()
+                    : Component.translatable(item.getType().translationKey());
+            }
+            case "getI18NDisplayName" ->
+                ((ItemStack) args[0]).getType().translationKey();
+            case "ensureServerConversions" -> {
+                ItemStack item = (ItemStack) args[0];
+                if (item instanceof PatchBukkitItemStack nativeItem) {
+                    yield nativeItem.clone();
+                }
+                PatchBukkitItemStack converted =
+                    PatchBukkitItemStack.create(item.getType(), item.getAmount());
+                ItemMeta meta = item.getItemMeta();
+                if (PatchBukkitItemMeta.owns(meta)) {
+                    converted.setItemMeta(meta);
+                }
+                yield converted;
+            }
+            case "hashCode" -> System.identityHashCode(proxy);
+            case "toString" -> "PatchBukkitItemFactory";
+            default -> throw new UnsupportedOperationException(
+                "PatchBukkit does not yet support ItemFactory#" + method.getName()
+            );
+        };
+    }
+
+    private static ItemStack createItemStack(String input) {
+        String value = Objects.requireNonNull(input, "input").trim();
+        if (value.isEmpty() || value.indexOf('{') >= 0 || value.indexOf('[') >= 0) {
+            throw new IllegalArgumentException(
+                "PatchBukkit currently accepts only a material name in createItemStack"
+            );
+        }
+        Material material = Material.matchMaterial(value);
+        if (material == null || !material.isItem()) {
+            throw new IllegalArgumentException("Unknown item material: " + input);
+        }
+        return PatchBukkitItemStack.create(material, 1);
+    }
+}
