+  uint32 slot = 2;
+}
+
+message SetHeldItemSlotResponse {
+  bool success = 1;
+}
+
+message SetCursorItemRequest {
+  patchbukkit.common.UUID player_uuid = 1;
+  patchbukkit.itemstack.ItemStack item = 2;
+}
+
+message SetCursorItemResponse {
+  bool success = 1;
