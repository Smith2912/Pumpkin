+package org.bukkit.craftbukkit.entity;
+
+import java.util.UUID;
+
+import org.bukkit.entity.HumanEntity;
+import org.bukkit.permissions.PermissibleBase;
+import org.patchbukkit.entity.PatchBukkitLivingEntity;
+
+/**
+ * CraftBukkit-compatible human-entity base used by permission plugins that
+ * replace the per-player {@code perm} delegate through reflection.
+ *
+ * <p>The field name, declaring class, type, and mutability are part of the
+ * practical CraftBukkit compatibility contract used by LuckPerms. Permission
+ * checks remain implemented by {@code PatchBukkitHumanEntity}; this class owns
+ * only the injectable delegate and the expected inheritance surface.</p>
+ */
+public abstract class CraftHumanEntity extends PatchBukkitLivingEntity implements HumanEntity {
+    protected PermissibleBase perm;
+
+    protected CraftHumanEntity(UUID uuid, String name) {
+        super(uuid, name);
+        this.perm = new PermissibleBase(this);
+    }
+}
diff --git a/java/patchbukkit/src/main/java/org/bukkit/plugin/SimplePluginManager.java b/java/patchbukkit/src/main/java/org/bukkit/plugin/SimplePluginManager.java
new file mode 100644
index 0000000000000000000000000000000000000000..735217e21407b0ef5c468dff7826d1fee28cd620
--- /dev/null
+++ b/java/patchbukkit/src/main/java/org/bukkit/plugin/SimplePluginManager.java
@@ -0,0 +1,214 @@
+package org.bukkit.plugin;
+
+import io.papermc.paper.plugin.PermissionManager;
+import java.util.HashMap;
+import java.util.HashSet;
+import java.util.LinkedHashMap;
+import java.util.LinkedHashSet;
+import java.util.List;
+import java.util.Locale;
+import java.util.Map;
+import java.util.Set;
+import java.util.WeakHashMap;
+import org.bukkit.Server;
+import org.bukkit.command.SimpleCommandMap;
+import org.bukkit.permissions.Permissible;
+import org.bukkit.permissions.Permission;
+import org.bukkit.permissions.PermissionDefault;
+import org.jetbrains.annotations.NotNull;
+import org.jetbrains.annotations.Nullable;
+
+/**
+ * PatchBukkit-compatible implementation base for Bukkit's standard plugin manager.
+ *
+ * <p>The Paper API ships this class as part of the API jar, but compatibility
+ * plugins such as LuckPerms require the runtime plugin manager to be an instance
+ * of it and replace its public permission maps. PatchBukkit supplies this
+ * source-level implementation so its bridge manager can extend the expected
+ * Bukkit type while retaining its native event integration.</p>
+ */
+@SuppressWarnings("removal")
+public abstract class SimplePluginManager implements PluginManager {
+    protected final Server server;
+    protected final SimpleCommandMap commandMap;
+
+    public Map<String, Permission> permissions = new HashMap<>();
+    public Map<Boolean, Set<Permission>> defaultPerms = new LinkedHashMap<>();
+    public Map<String, Map<Permissible, Boolean>> permSubs = new HashMap<>();
+    public Map<Boolean, Map<Permissible, Boolean>> defSubs = new HashMap<>();
+
+    private boolean useTimings;
+
+    protected SimplePluginManager(Server server, SimpleCommandMap commandMap) {
+        this.server = server;
+        this.commandMap = commandMap;
+        this.defaultPerms.put(true, new LinkedHashSet<>());
+        this.defaultPerms.put(false, new LinkedHashSet<>());
+    }
+
+    @Override
+    public @Nullable Permission getPermission(@NotNull String name) {
+        return this.permissions.get(name.toLowerCase(Locale.ENGLISH));
+    }
+
+    @Override
+    public void addPermission(@NotNull Permission permission) {
+        addPermission(permission, true);
+    }
+
+    @Override
+    public void addPermissions(@NotNull List<Permission> permissions) {
+        for (Permission permission : permissions) {
+            addPermission(permission, false);
+        }
+        dirtyPermissibles();
+    }
+
+    public void addPermission(@NotNull Permission permission, boolean dirty) {
+        String name = permission.getName().toLowerCase(Locale.ENGLISH);
+        if (this.permissions.containsKey(name)) {
+            throw new IllegalArgumentException("The permission " + name + " is already defined!");
+        }
+
+        this.permissions.put(name, permission);
+        calculatePermissionDefault(permission, dirty);
+    }
+
+    @Override
+    public void removePermission(@NotNull Permission permission) {
+        removePermission(permission.getName());
+    }
+
+    @Override
+    public void removePermission(@NotNull String name) {
+        this.permissions.remove(name.toLowerCase(Locale.ENGLISH));
+    }
+
+    @Override
+    public @NotNull Set<Permission> getDefaultPermissions(boolean op) {
+        return Set.copyOf(this.defaultPerms.computeIfAbsent(op, ignored -> new LinkedHashSet<>()));
+    }
+
+    @Override
+    public void recalculatePermissionDefaults(@NotNull Permission permission) {
+        String name = permission.getName().toLowerCase(Locale.ENGLISH);
+        if (!this.permissions.containsKey(name)) {
+            return;
+        }
+
+        this.defaultPerms.computeIfAbsent(true, ignored -> new LinkedHashSet<>()).remove(permission);
+        this.defaultPerms.computeIfAbsent(false, ignored -> new LinkedHashSet<>()).remove(permission);
+        calculatePermissionDefault(permission, true);
+    }
+
+    private void calculatePermissionDefault(@NotNull Permission permission, boolean dirty) {
+        PermissionDefault value = permission.getDefault();
+        if (value == PermissionDefault.OP || value == PermissionDefault.TRUE) {
+            this.defaultPerms.computeIfAbsent(true, ignored -> new LinkedHashSet<>()).add(permission);
+            if (dirty) {
+                dirtyPermissibles(true);
+            }
+        }
+        if (value == PermissionDefault.NOT_OP || value == PermissionDefault.TRUE) {
+            this.defaultPerms.computeIfAbsent(false, ignored -> new LinkedHashSet<>()).add(permission);
+            if (dirty) {
+                dirtyPermissibles(false);
+            }
+        }
+    }
+
+    @Override
+    public void subscribeToPermission(@NotNull String permission, @NotNull Permissible permissible) {
+        String name = permission.toLowerCase(Locale.ENGLISH);
+        this.permSubs.computeIfAbsent(name, ignored -> new WeakHashMap<>()).put(permissible, true);
+    }
+
+    @Override
+    public void unsubscribeFromPermission(@NotNull String permission, @NotNull Permissible permissible) {
+        String name = permission.toLowerCase(Locale.ENGLISH);
+        Map<Permissible, Boolean> subscribers = this.permSubs.get(name);
+        if (subscribers == null) {
+            return;
+        }
+
+        subscribers.remove(permissible);
+        if (subscribers.isEmpty()) {
+            this.permSubs.remove(name);
+        }
+    }
+
+    @Override
+    public @NotNull Set<Permissible> getPermissionSubscriptions(@NotNull String permission) {
+        Map<Permissible, Boolean> subscribers =
+            this.permSubs.get(permission.toLowerCase(Locale.ENGLISH));
+        return subscribers == null ? Set.of() : Set.copyOf(subscribers.keySet());
+    }
+
+    @Override
+    public void subscribeToDefaultPerms(boolean op, @NotNull Permissible permissible) {
+        this.defSubs.computeIfAbsent(op, ignored -> new WeakHashMap<>()).put(permissible, true);
+    }
+
+    @Override
+    public void unsubscribeFromDefaultPerms(boolean op, @NotNull Permissible permissible) {
+        Map<Permissible, Boolean> subscribers = this.defSubs.get(op);
+        if (subscribers == null) {
+            return;
+        }
+
+        subscribers.remove(permissible);
+        if (subscribers.isEmpty()) {
+            this.defSubs.remove(op);
+        }
+    }
+
+    @Override
+    public @NotNull Set<Permissible> getDefaultPermSubscriptions(boolean op) {
+        Map<Permissible, Boolean> subscribers = this.defSubs.get(op);
+        return subscribers == null ? Set.of() : Set.copyOf(subscribers.keySet());
+    }
+
+    @Override
+    public @NotNull Set<Permission> getPermissions() {
+        return new HashSet<>(this.permissions.values());
+    }
+
+    @Override
+    public void clearPermissions() {
+        this.permissions.clear();
+        this.defaultPerms.computeIfAbsent(true, ignored -> new LinkedHashSet<>()).clear();
+        this.defaultPerms.computeIfAbsent(false, ignored -> new LinkedHashSet<>()).clear();
+    }
+
+    protected void dirtyPermissibles(boolean op) {
+        for (Permissible permissible : getDefaultPermSubscriptions(op)) {
+            permissible.recalculatePermissions();
+        }
+    }
+
+    protected void dirtyPermissibles() {
+        dirtyPermissibles(true);
+        dirtyPermissibles(false);
+    }
+
+    @Override
+    public void overridePermissionManager(
+        @NotNull Plugin plugin,
+        @Nullable PermissionManager permissionManager
+    ) {
+        if (permissionManager != null && permissionManager != this) {
+            throw new UnsupportedOperationException(
+                "PatchBukkit cannot replace its compatibility permission manager"
+            );
+        }
+    }
+
+    @Override
+    public boolean useTimings() {
+        return this.useTimings;
+    }
+
+    public void useTimings(boolean useTimings) {
+        this.useTimings = useTimings;
+    }
+}
