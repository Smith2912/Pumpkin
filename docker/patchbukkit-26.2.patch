+    @ConformanceTest(name = "Online player presentation round-trips through Pumpkin", category = TestCategory.ENTITY)
+    public void testOnlinePlayerPresentationRoundTrip() {
+        Player player = Bukkit.getOnlinePlayers().stream().findFirst().orElse(null);
+        if (player == null) {
+            return;
+        }
+
+        Component originalDisplayName = player.displayName();
+        Component originalListName = player.playerListName();
+        String originalHeader = player.getPlayerListHeader();
+        String originalFooter = player.getPlayerListFooter();
+        int originalOrder = player.getPlayerListOrder();
+        int replacementOrder = originalOrder == Integer.MAX_VALUE
+            ? originalOrder - 1
+            : originalOrder + 1;
+        Component replacementDisplayName = Component.text("[PB] ").append(originalDisplayName);
+        Component replacementListName = Component.text("[PB] ").append(Component.text(player.getName()));
+
+        try {
+            player.displayName(replacementDisplayName);
+            player.playerListName(replacementListName);
+            player.setPlayerListHeaderFooter("PatchBukkit header", "PatchBukkit footer");
+            player.setPlayerListOrder(replacementOrder);
+
+            assertTrue(
+                replacementDisplayName.equals(player.displayName()),
+                "display name should round-trip"
+            );
+            assertTrue(
+                replacementListName.equals(player.playerListName()),
+                "player-list name should round-trip"
+            );
+            assertTrue(
+                "PatchBukkit header".equals(player.getPlayerListHeader()),
+                "player-list header should round-trip"
+            );
+            assertTrue(
+                "PatchBukkit footer".equals(player.getPlayerListFooter()),
+                "player-list footer should round-trip"
+            );
+            assertTrue(
+                player.getPlayerListOrder() == replacementOrder,
+                "player-list order should round-trip"
+            );
+        } finally {
+            player.displayName(originalDisplayName);
+            player.playerListName(originalListName);
+            player.setPlayerListHeaderFooter(originalHeader, originalFooter);
+            player.setPlayerListOrder(originalOrder);
+        }
+    }
