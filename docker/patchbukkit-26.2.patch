+}
+
+// Complete replacement state for the Bukkit metadata subset PatchBukkit
+// currently supports. `modified` is false for read-only snapshots and true
+// only after a plugin calls ItemStack#setItemMeta.
+message ItemMetadata {
+  optional string display_name = 1;
+  repeated string lore = 2;
+  map<string, int32> enchantments = 3;
+  optional int32 damage = 4;
+  optional int32 repair_cost = 5;
+  bool unbreakable = 6;
+  bool modified = 7;
 }
diff --git a/proto/patchbukkit/player.proto b/proto/patchbukkit/player.proto
new file mode 100644
index 0000000000000000000000000000000000000000..4c6f344ab72d07f7ec034885ff1437dc967aca9c
--- /dev/null
+++ b/proto/patchbukkit/player.proto
@@ -0,0 +1,169 @@
+syntax = "proto3";
+
+package patchbukkit.player;
+
+import "patchbukkit/common/types.proto";
+import "patchbukkit/itemstack.proto";
+
+option java_multiple_files = true;
+option java_package = "patchbukkit.player";
+
+message PlayerGameMode {
+  string current = 1;
+  optional string previous = 2;
+}
+
+message SetPlayerGameModeRequest {
+  patchbukkit.common.UUID player_uuid = 1;
+  string game_mode = 2;
+}
+
+message SetPlayerGameModeResponse {
+  bool success = 1;
+}
+
+message PlayerVitals {
+  double health = 1;
+  double max_health = 2;
+  double absorption = 3;
+  int32 food_level = 4;
+  float saturation = 5;
+  float exhaustion = 6;
+}
+
+message UpdatePlayerVitalsRequest {
+  patchbukkit.common.UUID player_uuid = 1;
+  optional double health = 2;
+  optional double max_health = 3;
+  optional double absorption = 4;
+  optional int32 food_level = 5;
+  optional float saturation = 6;
+  optional float exhaustion = 7;
+}
+
+message UpdatePlayerVitalsResponse {
+  bool success = 1;
+}
+
+message PlayerSessionState {
+  bool sprinting = 1;
+  bool sneaking = 2;
+  uint32 ping = 3;
+  string locale = 4;
+}
+
+message UpdatePlayerSessionStateRequest {
+  patchbukkit.common.UUID player_uuid = 1;
+  optional bool sprinting = 2;
+  optional bool sneaking = 3;
+}
+
+message UpdatePlayerSessionStateResponse {
+  bool success = 1;
+}
+
+message KickPlayerRequest {
+  patchbukkit.common.UUID player_uuid = 1;
+  string reason_json = 2;
+}
+
+message KickPlayerResponse {
+  bool success = 1;
+}
+
+message PerformPlayerCommandRequest {
+  patchbukkit.common.UUID player_uuid = 1;
+  string command = 2;
+}
+
+message PerformPlayerCommandResponse {
+  bool success = 1;
+}
+
+message NullableTextComponent {
+  optional string json = 1;
+}
+
+message PlayerPresentationState {
+  optional string display_name_json = 1;
+  optional string player_list_name_json = 2;
+  string player_list_header_json = 3;
+  string player_list_footer_json = 4;
+  int32 player_list_order = 5;
+}
+
+message UpdatePlayerPresentationRequest {
+  patchbukkit.common.UUID player_uuid = 1;
+  optional NullableTextComponent display_name = 2;
+  optional NullableTextComponent player_list_name = 3;
+  optional string player_list_header_json = 4;
+  optional string player_list_footer_json = 5;
+  optional int32 player_list_order = 6;
+}
+
+message UpdatePlayerPresentationResponse {
+  bool success = 1;
+}
+
+message SendPlayerActionBarRequest {
+  patchbukkit.common.UUID player_uuid = 1;
+  string message_json = 2;
+}
+
+message SendPlayerActionBarResponse {
+  bool success = 1;
+}
+
+message TeleportPlayerRequest {
+  patchbukkit.common.UUID player_uuid = 1;
+  patchbukkit.common.Location destination = 2;
+}
+
+message TeleportPlayerResponse {
+  bool success = 1;
+}
+
+enum InventoryKind {
+  INVENTORY_KIND_UNSPECIFIED = 0;
+  INVENTORY_KIND_PLAYER = 1;
+  INVENTORY_KIND_ENDER_CHEST = 2;
+}
+
+message GetInventoryRequest {
+  patchbukkit.common.UUID player_uuid = 1;
+  InventoryKind kind = 2;
+}
+
+message InventorySnapshot {
+  repeated patchbukkit.itemstack.ItemStack contents = 1;
+  optional uint32 held_item_slot = 2;
+}
+
+message SetInventoryItemRequest {
+  patchbukkit.common.UUID player_uuid = 1;
+  InventoryKind kind = 2;
+  uint32 slot = 3;
+  patchbukkit.itemstack.ItemStack item = 4;
+}
+
+message SetInventoryItemResponse {
+  bool success = 1;
+}
+
+message SetHeldItemSlotRequest {
+  patchbukkit.common.UUID player_uuid = 1;
+  uint32 slot = 2;
+}
+
+message SetHeldItemSlotResponse {
+  bool success = 1;
+}
+
+message SetCursorItemRequest {
+  patchbukkit.common.UUID player_uuid = 1;
+  patchbukkit.itemstack.ItemStack item = 2;
+}
+
+message SetCursorItemResponse {
+  bool success = 1;
+}
