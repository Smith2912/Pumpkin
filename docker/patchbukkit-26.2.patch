+package org.patchbukkit.inventory;
+
+import java.util.ArrayList;
+import java.util.Arrays;
+import java.util.Collections;
+import java.util.HashMap;
+import java.util.List;
+import java.util.ListIterator;
+import java.util.Objects;
+import java.util.UUID;
+import java.util.stream.IntStream;
+
+import org.bukkit.Location;
+import org.bukkit.Material;
+import org.bukkit.entity.HumanEntity;
+import org.bukkit.event.inventory.InventoryType;
+import org.bukkit.inventory.Inventory;
+import org.bukkit.inventory.InventoryHolder;
+import org.bukkit.inventory.ItemStack;
+import org.jetbrains.annotations.Nullable;
+import org.patchbukkit.bridge.BridgeUtils;
+
+import patchbukkit.bridge.NativeBridgeFfi;
+import patchbukkit.player.GetInventoryRequest;
+import patchbukkit.player.InventoryKind;
+import patchbukkit.player.InventorySnapshot;
+import patchbukkit.player.SetInventoryItemRequest;
+
+/**
+ * Live Bukkit inventory view backed by Pumpkin bridge snapshots.
+ */
+public class PatchBukkitInventory implements Inventory {
+    protected final UUID playerUuid;
+    protected final InventoryKind kind;
+    protected final HumanEntity holder;
+    private final int size;
+    private final InventoryType type;
+    private int maxStackSize = 64;
+
+    public PatchBukkitInventory(
+        UUID playerUuid,
+        InventoryKind kind,
+        HumanEntity holder,
+        int size,
+        InventoryType type
+    ) {
+        this.playerUuid = Objects.requireNonNull(playerUuid, "playerUuid");
+        this.kind = Objects.requireNonNull(kind, "kind");
+        this.holder = Objects.requireNonNull(holder, "holder");
+        this.size = size;
+        this.type = Objects.requireNonNull(type, "type");
+    }
+
+    protected InventorySnapshot snapshot() {
+        InventorySnapshot snapshot = NativeBridgeFfi.getInventory(
+            GetInventoryRequest.newBuilder()
+                .setPlayerUuid(BridgeUtils.convertUuid(this.playerUuid))
+                .setKind(this.kind)
+                .build()
+        );
+        if (snapshot == null || snapshot.getContentsCount() != this.size) {
+            throw new IllegalStateException(
+                "Failed to read " + this.kind + " inventory for player " + this.playerUuid
+            );
+        }
+        return snapshot;
+    }
+
+    protected int[] storageSlots() {
+        return IntStream.range(0, this.size).toArray();
+    }
+
+    protected static boolean isEmpty(@Nullable ItemStack item) {
+        return item == null || item.getType() == Material.AIR || item.getAmount() <= 0;
+    }
+
+    protected static boolean similar(@Nullable ItemStack first, @Nullable ItemStack second) {
+        if (isEmpty(first) || isEmpty(second)) {
+            return isEmpty(first) && isEmpty(second);
+        }
+        if (first instanceof PatchBukkitItemStack nativeItem) {
+            return nativeItem.bridgeSimilar(second);
+        }
+        if (second instanceof PatchBukkitItemStack nativeItem) {
+            return nativeItem.bridgeSimilar(first);
+        }
+        return first.getType() == second.getType()
+            && !first.hasItemMeta()
+            && !second.hasItemMeta();
+    }
+
+    protected void validateSlot(int slot) {
+        if (slot < 0 || slot >= this.size) {
+            throw new IndexOutOfBoundsException(
+                "Inventory slot " + slot + " is outside 0.." + (this.size - 1)
+            );
+        }
+    }
+
+    @Override
+    public int getSize() {
+        return this.size;
+    }
+
+    @Override
+    public int getMaxStackSize() {
+        return this.maxStackSize;
+    }
+
+    @Override
+    public void setMaxStackSize(int size) {
+        if (size < 1 || size > 255) {
+            throw new IllegalArgumentException("Max stack size must be between 1 and 255");
+        }
+        this.maxStackSize = size;
+    }
+
+    @Override
+    public @Nullable ItemStack getItem(int index) {
+        this.validateSlot(index);
+        return PatchBukkitItemStack.fromBridge(this.snapshot().getContents(index));
+    }
+
+    @Override
+    public void setItem(int index, @Nullable ItemStack item) {
+        this.validateSlot(index);
+        var response = NativeBridgeFfi.setInventoryItem(
+            SetInventoryItemRequest.newBuilder()
+                .setPlayerUuid(BridgeUtils.convertUuid(this.playerUuid))
+                .setKind(this.kind)
+                .setSlot(index)
+                .setItem(PatchBukkitItemStack.toBridge(item))
+                .build()
+        );
+        if (response == null || !response.getSuccess()) {
+            throw new IllegalStateException(
+                "Failed to update " + this.kind + " slot " + index
+                    + " for player " + this.playerUuid
+            );
+        }
+    }
+
+    private int stackLimit(ItemStack item) {
+        return Math.min(this.maxStackSize, item.getType().getMaxStackSize());
+    }
+
+    @Override
+    public HashMap<Integer, ItemStack> addItem(ItemStack... items) {
+        Objects.requireNonNull(items, "items");
+        HashMap<Integer, ItemStack> leftovers = new HashMap<>();
+        ItemStack[] contents = this.getContents();
+        int[] slots = this.storageSlots();
+
+        for (int inputIndex = 0; inputIndex < items.length; inputIndex++) {
+            ItemStack input = Objects.requireNonNull(items[inputIndex], "item").clone();
+            if (isEmpty(input)) {
+                continue;
+            }
+
+            int remaining = input.getAmount();
+            for (int slot : slots) {
+                ItemStack current = contents[slot];
+                if (!similar(current, input)) {
+                    continue;
+                }
+                int capacity = this.stackLimit(current) - current.getAmount();
+                if (capacity <= 0) {
+                    continue;
+                }
+                int moved = Math.min(capacity, remaining);
+                current.setAmount(current.getAmount() + moved);
+                this.setItem(slot, current);
+                remaining -= moved;
+                if (remaining == 0) {
+                    break;
+                }
+            }
+
+            for (int slot : slots) {
+                if (remaining == 0) {
+                    break;
+                }
+                if (!isEmpty(contents[slot])) {
+                    continue;
+                }
+                int moved = Math.min(this.stackLimit(input), remaining);
+                ItemStack inserted = input.clone();
+                inserted.setAmount(moved);
+                contents[slot] = inserted;
+                this.setItem(slot, inserted);
+                remaining -= moved;
+            }
+
+            if (remaining > 0) {
+                input.setAmount(remaining);
+                leftovers.put(inputIndex, input);
+            }
+        }
+        return leftovers;
+    }
+
+    private HashMap<Integer, ItemStack> removeItems(boolean anySlot, ItemStack... items) {
+        Objects.requireNonNull(items, "items");
+        HashMap<Integer, ItemStack> leftovers = new HashMap<>();
+        ItemStack[] contents = this.getContents();
+        int[] slots = anySlot
+            ? IntStream.range(0, this.size).toArray()
+            : this.storageSlots();
+
+        for (int inputIndex = 0; inputIndex < items.length; inputIndex++) {
+            ItemStack input = Objects.requireNonNull(items[inputIndex], "item").clone();
+            if (isEmpty(input)) {
+                continue;
+            }
+
+            int remaining = input.getAmount();
+            for (int slot : slots) {
+                ItemStack current = contents[slot];
+                if (!similar(current, input)) {
+                    continue;
+                }
+                int removed = Math.min(current.getAmount(), remaining);
+                int newAmount = current.getAmount() - removed;
+                contents[slot] = newAmount == 0 ? null : current;
+                if (newAmount > 0) {
+                    current.setAmount(newAmount);
+                }
+                this.setItem(slot, contents[slot]);
+                remaining -= removed;
+                if (remaining == 0) {
+                    break;
+                }
+            }
+
+            if (remaining > 0) {
+                input.setAmount(remaining);
+                leftovers.put(inputIndex, input);
+            }
+        }
+        return leftovers;
+    }
+
+    @Override
+    public HashMap<Integer, ItemStack> removeItem(ItemStack... items) {
+        return this.removeItems(false, items);
+    }
+
+    @Override
+    public HashMap<Integer, ItemStack> removeItemAnySlot(ItemStack... items) {
+        return this.removeItems(true, items);
+    }
+
+    @Override
+    public ItemStack[] getContents() {
