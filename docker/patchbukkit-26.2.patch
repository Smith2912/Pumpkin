+    private int stateHash() {
+        return Objects.hash(
+            this.material,
+            this.displayName,
+            this.lore,
+            this.enchantments,
+            this.itemFlags,
+            this.damage,
+            this.repairCost,
+            this.unbreakable
+        );
+    }
+
+    private String describe() {
+        return "PatchBukkitItemMeta" + this.serialize();
+    }
+
+    private static Object defaultOrUnsupported(Method method) {
+        String name = method.getName();
+        Class<?> returnType = method.getReturnType();
+        if (name.startsWith("has") || name.startsWith("is")) {
