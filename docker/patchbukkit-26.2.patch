+    @ConformanceTest(name = "PluginManager exposes Bukkit permission maps", category = TestCategory.PLUGIN_MANAGER)
+    public void testSimplePluginManagerCompatibility() throws Exception {
+        PluginManager manager = Bukkit.getPluginManager();
+        assertTrue(
+            manager instanceof SimplePluginManager,
+            "PluginManager should be a SimplePluginManager for Bukkit permission providers"
+        );
+
+        Permission marker = new Permission("patchbukkit.test.permission-map");
+        manager.addPermission(marker);
+        try {
+            Field permissionsField = SimplePluginManager.class.getDeclaredField("permissions");
+            permissionsField.setAccessible(true);
+            @SuppressWarnings("unchecked")
+            Map<String, Permission> permissions =
+                (Map<String, Permission>) permissionsField.get(manager);
+            assertTrue(
+                permissions.get(marker.getName()) == marker,
+                "PluginManager methods should use the replaceable Bukkit permission map"
+            );
+        } finally {
+            manager.removePermission(marker);
+        }
+    }
+
 }
