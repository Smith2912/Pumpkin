+
+pub fn ffi_native_bridge_get_worlds_impl(
+    _request: crate::proto::patchbukkit::common::EmptyRequest,
+) -> Option<crate::proto::patchbukkit::common::WorldList> {
+    let ctx = CALLBACK_CONTEXT.get()?;
+    let worlds = ctx.plugin_context.server.worlds.load();
+    let worlds = worlds
+        .iter()
+        .map(|world| {
+            let level_info = world.level_info.load();
+            World {
+                uuid: Some(Uuid {
+                    value: world.uuid.to_string(),
+                }),
+                name: world.get_world_name().to_string(),
+                dimension: world.dimension.minecraft_name.to_string(),
+                min_height: world.min_y,
+                max_height: world.min_y + world.dimension.height,
+                spawn_x: f64::from(level_info.spawn_x) + 0.5,
+                spawn_y: f64::from(level_info.spawn_y),
+                spawn_z: f64::from(level_info.spawn_z) + 0.5,
+                spawn_yaw: level_info.spawn_yaw,
+                spawn_pitch: level_info.spawn_pitch,
+            }
+        })
+        .collect();
+
+    Some(crate::proto::patchbukkit::common::WorldList { worlds })
+}
