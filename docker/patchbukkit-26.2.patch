@@ -0,0 +1,154 @@
+package org.patchbukkit.registry;
+
+import org.bukkit.Fluid;
+import org.bukkit.GameEvent;
+import org.bukkit.Keyed;
+import org.bukkit.Material;
+import org.bukkit.NamespacedKey;
+import org.bukkit.Registry;
+import org.bukkit.Tag;
+import org.bukkit.entity.EntityType;
+import org.jetbrains.annotations.NotNull;
+import org.jetbrains.annotations.Nullable;
+import patchbukkit.bridge.NativeBridgeFfi;
+import patchbukkit.registry.GetRegistryDataRequest;
+import patchbukkit.registry.GetRegistryDataResponse;
+import patchbukkit.registry.RegistryTagData;
+import patchbukkit.registry.RegistryType;
+
+import java.util.Collections;
+import java.util.LinkedHashMap;
+import java.util.LinkedHashSet;
+import java.util.Map;
+import java.util.Set;
+import java.util.concurrent.ConcurrentHashMap;
+
+public final class PatchBukkitLegacyTags {
+    private static final Map<CacheKey, Map<NamespacedKey, Tag<?>>> CACHE =
+        new ConcurrentHashMap<>();
+
+    private PatchBukkitLegacyTags() {
+    }
+
+    public static <T extends Keyed> @Nullable Tag<T> getTag(
+        @NotNull String registry,
+        @NotNull NamespacedKey tag,
+        @NotNull Class<T> type
+    ) {
+        return getTagsFor(registry, type).get(tag);
+    }
+
+    public static <T extends Keyed> @NotNull Iterable<Tag<T>> getTags(
+        @NotNull String registry,
+        @NotNull Class<T> type
+    ) {
+        return Collections.unmodifiableCollection(getTagsFor(registry, type).values());
+    }
+
+    @SuppressWarnings("unchecked")
+    private static <T extends Keyed> Map<NamespacedKey, Tag<T>> getTagsFor(
+        String registry,
+        Class<T> type
+    ) {
+        CacheKey cacheKey = new CacheKey(registry, type);
+        return (Map<NamespacedKey, Tag<T>>) (Map<?, ?>) CACHE.computeIfAbsent(
+            cacheKey,
+            ignored -> loadTags(registry, type)
+        );
+    }
+
+    private static <T extends Keyed> Map<NamespacedKey, Tag<?>> loadTags(
+        String registry,
+        Class<T> type
+    ) {
+        RegistryType registryType = registryType(registry);
+        if (registryType == null || !supports(registry, type)) {
+            return Collections.emptyMap();
+        }
+
+        GetRegistryDataResponse response = NativeBridgeFfi.getRegistryData(
+            GetRegistryDataRequest.newBuilder().setRegistry(registryType).build()
+        );
+        if (response == null || !response.hasTagRegistry()) {
+            return Collections.emptyMap();
+        }
+
+        Map<NamespacedKey, Tag<?>> result = new LinkedHashMap<>();
+        for (RegistryTagData data : response.getTagRegistry().getTagsList()) {
+            NamespacedKey tagKey = namespacedKey(data.getName());
+            if (tagKey == null) {
+                continue;
+            }
+
+            Set<NamespacedKey> valueKeys = new LinkedHashSet<>();
+            for (String rawValue : data.getValuesList()) {
+                NamespacedKey valueKey = namespacedKey(rawValue);
+                if (valueKey != null) {
+                    valueKeys.add(valueKey);
+                }
+            }
+            result.put(
+                tagKey,
+                new PatchBukkitLegacyTag<>(tagKey, valueKeys, key -> resolve(type, key))
+            );
+        }
+        return Collections.unmodifiableMap(result);
+    }
+
+    private static @Nullable RegistryType registryType(String registry) {
+        return switch (registry) {
+            case "blocks" -> RegistryType.BLOCK_TAGS;
+            case "items" -> RegistryType.ITEM_TAGS;
+            case "fluids" -> RegistryType.FLUID_TAGS;
+            case "entity_types" -> RegistryType.ENTITY_TYPE_TAGS;
+            case "game_events" -> RegistryType.GAME_EVENT_TAGS;
+            default -> null;
+        };
+    }
+
+    private static boolean supports(String registry, Class<?> type) {
+        return ("blocks".equals(registry) && type == Material.class)
+            || ("items".equals(registry) && type == Material.class)
+            || ("fluids".equals(registry) && type == Fluid.class)
+            || ("entity_types".equals(registry) && type == EntityType.class)
+            || ("game_events".equals(registry) && type == GameEvent.class);
+    }
+
+    @SuppressWarnings("unchecked")
+    private static <T extends Keyed> @Nullable T resolve(
+        Class<T> type,
+        NamespacedKey key
+    ) {
+        if (type == Material.class) {
+            return (T) Material.matchMaterial(key.asString());
+        }
+        if (type == Fluid.class) {
