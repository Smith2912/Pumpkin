+    }
+
+    @Override
+    public @NotNull Set<ProfileProperty> getProperties() {
+        return this.properties;
+    }
+
+    @Override
+    public boolean hasProperty(@NotNull String property) {
+        return this.properties.stream().anyMatch(value -> value.getName().equals(property));
+    }
+
+    @Override
+    public void setProperty(@NotNull ProfileProperty property) {
+        removeProperty(property.getName());
+        this.properties.add(property);
+    }
+
+    @Override
+    public void setProperties(@NotNull Collection<ProfileProperty> properties) {
+        properties.forEach(this::setProperty);
+    }
+
+    @Override
+    public boolean removeProperty(@NotNull String property) {
+        return this.properties.removeIf(value -> value.getName().equals(property));
+    }
+
+    @Override
+    public void clearProperties() {
+        this.properties.clear();
+    }
+
+    @Override
+    public boolean isComplete() {
+        return this.id != null && this.name != null && !this.name.isBlank();
+    }
+
+    @Override
