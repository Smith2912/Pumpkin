+
+    #[test]
+    fn discovery_ignores_nested_dependency_jars() {
+        let root = std::env::temp_dir().join(format!(
+            "patchbukkit-jar-discovery-{}",
+            uuid::Uuid::new_v4()
+        ));
+        let nested = root.join("PluginData").join("libs");
+        fs::create_dir_all(&nested).expect("create test directories");
+        fs::write(root.join("plugin.jar"), []).expect("create plugin jar");
+        fs::write(nested.join("dependency.jar"), []).expect("create dependency jar");
+
+        let jars: Vec<_> = discover_jar_files(&root).collect();
+
+        assert_eq!(jars.len(), 1);
+        assert_eq!(
+            jars[0].file_name().and_then(|name| name.to_str()),
+            Some("plugin.jar")
+        );
+        fs::remove_dir_all(root).expect("remove test directories");
+    }
