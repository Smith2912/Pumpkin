+  DAMAGE_EFFECT_POKING = 4;
+  DAMAGE_EFFECT_FREEZING = 5;
+}
+
+enum DeathMessageTypeKind {
+  DEATH_MESSAGE_DEFAULT = 0;
+  DEATH_MESSAGE_FALL_VARIANTS = 1;
+  DEATH_MESSAGE_INTENTIONAL_GAME_DESIGN = 2;
+}
+
+message DamageTypeData {
+  string name = 1;
+  string translation_key = 2;
+  DamageScalingKind scaling = 3;
+  DamageEffectKind effect = 4;
+  DeathMessageTypeKind death_message_type = 5;
+  float exhaustion = 6;
+}
+
+message DamageTypeRegistryData {
+  repeated DamageTypeData damage_types = 1;
+}
diff --git a/proto/patchbukkit/world.proto b/proto/patchbukkit/world.proto
new file mode 100644
index 0000000000000000000000000000000000000000..c98a9f1374f51dea3b66852a83f86d79e38813a6
--- /dev/null
