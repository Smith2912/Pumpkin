+package org.patchbukkit.registry;
+
+import java.util.Objects;
+import org.bukkit.NamespacedKey;
+import org.bukkit.Registry;
+import org.bukkit.Sound;
+import org.bukkit.damage.DamageEffect;
+import org.bukkit.damage.DamageScaling;
+import org.bukkit.damage.DamageType;
+import org.bukkit.damage.DeathMessageType;
+import org.jetbrains.annotations.NotNull;
+import patchbukkit.registry.DamageTypeData;
+
+final class PatchBukkitDamageType implements DamageType {
+    private final NamespacedKey key;
+    private final String translationKey;
+    private final DamageScaling scaling;
+    private final DamageEffect effect;
+    private final DeathMessageType deathMessageType;
+    private final float exhaustion;
+
+    PatchBukkitDamageType(DamageTypeData data) {
+        this.key = Objects.requireNonNull(NamespacedKey.minecraft(data.getName()));
+        this.translationKey = data.getTranslationKey();
+        this.scaling = switch (data.getScaling()) {
+            case DAMAGE_SCALING_ALWAYS -> DamageScaling.ALWAYS;
+            case DAMAGE_SCALING_WHEN_CAUSED_BY_LIVING_NON_PLAYER ->
+                DamageScaling.WHEN_CAUSED_BY_LIVING_NON_PLAYER;
+            default -> DamageScaling.NEVER;
+        };
+        this.effect = PatchBukkitDamageEffect.fromName(
+            data.getEffect().name().substring("DAMAGE_EFFECT_".length()).toLowerCase()
+        );
+        this.deathMessageType = switch (data.getDeathMessageType()) {
+            case DEATH_MESSAGE_FALL_VARIANTS -> DeathMessageType.FALL_VARIANTS;
+            case DEATH_MESSAGE_INTENTIONAL_GAME_DESIGN ->
+                DeathMessageType.INTENTIONAL_GAME_DESIGN;
+            default -> DeathMessageType.DEFAULT;
+        };
+        this.exhaustion = data.getExhaustion();
+    }
+
+    @Override
+    public @NotNull NamespacedKey getKey() {
+        return key;
+    }
+
+    @Override
+    public @NotNull String getTranslationKey() {
+        return translationKey;
+    }
+
+    @Override
+    public @NotNull DamageScaling getDamageScaling() {
+        return scaling;
+    }
+
+    @Override
+    public @NotNull DamageEffect getDamageEffect() {
+        return effect;
+    }
+
+    @Override
+    public @NotNull DeathMessageType getDeathMessageType() {
+        return deathMessageType;
+    }
+
+    @Override
+    public float getExhaustion() {
+        return exhaustion;
+    }
+
+    private enum PatchBukkitDamageEffect implements DamageEffect {
+        HURT("entity.player.hurt"),
+        THORNS("enchant.thorns.hit"),
+        DROWNING("entity.player.hurt_drown"),
+        BURNING("entity.player.hurt_on_fire"),
+        POKING("entity.player.hurt_sweet_berry_bush"),
+        FREEZING("entity.player.hurt_freeze");
+
+        private final NamespacedKey soundKey;
+
+        PatchBukkitDamageEffect(String soundName) {
+            this.soundKey = NamespacedKey.minecraft(soundName);
+        }
+
+        static DamageEffect fromName(String name) {
+            return valueOf(name.toUpperCase());
+        }
+
+        @Override
+        public @NotNull Sound getSound() {
+            return Objects.requireNonNull(
+                Registry.SOUNDS.get(soundKey),
+                () -> "Missing damage-effect sound " + soundKey
+            );
+        }
+    }
+}
