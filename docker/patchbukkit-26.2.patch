+++ b/java/patchbukkit/src/main/java/org/patchbukkit/inventory/PatchBukkitPlayerInventory.java
@@ -0,0 +1,336 @@
+package org.patchbukkit.inventory;
+
+import java.util.EnumMap;
+import java.util.Map;
+import java.util.UUID;
+import java.util.stream.IntStream;
+
+import org.bukkit.entity.HumanEntity;
+import org.bukkit.event.inventory.InventoryType;
+import org.bukkit.inventory.EntityEquipment;
+import org.bukkit.inventory.EquipmentSlot;
+import org.bukkit.inventory.ItemStack;
+import org.bukkit.inventory.PlayerInventory;
+import org.jetbrains.annotations.Nullable;
+import org.patchbukkit.bridge.BridgeUtils;
+
+import patchbukkit.bridge.NativeBridgeFfi;
+import patchbukkit.player.GetInventoryRequest;
+import patchbukkit.player.InventoryKind;
+import patchbukkit.player.SetHeldItemSlotRequest;
+
+/**
+ * Pumpkin-backed player inventory and equipment view.
+ */
+public final class PatchBukkitPlayerInventory
+    extends PatchBukkitInventory
+    implements PlayerInventory, EntityEquipment {
+    private static final int BOOTS_SLOT = 36;
+    private static final int LEGGINGS_SLOT = 37;
+    private static final int CHESTPLATE_SLOT = 38;
+    private static final int HELMET_SLOT = 39;
+    private static final int OFF_HAND_SLOT = 40;
+
+    private final Map<EquipmentSlot, Float> dropChances =
+        new EnumMap<>(EquipmentSlot.class);
+
+    public PatchBukkitPlayerInventory(UUID playerUuid, HumanEntity holder) {
+        super(playerUuid, InventoryKind.INVENTORY_KIND_PLAYER, holder, 41, InventoryType.PLAYER);
+    }
+
+    @Override
+    protected int[] storageSlots() {
+        return IntStream.range(0, 36).toArray();
+    }
+
+    @Override
+    public ItemStack[] getArmorContents() {
+        ItemStack[] contents = this.getContents();
+        return new ItemStack[] {
+            contents[BOOTS_SLOT],
+            contents[LEGGINGS_SLOT],
+            contents[CHESTPLATE_SLOT],
+            contents[HELMET_SLOT]
+        };
+    }
+
+    @Override
+    public ItemStack[] getExtraContents() {
+        return new ItemStack[] { this.getItem(OFF_HAND_SLOT) };
+    }
+
+    @Override
+    public @Nullable ItemStack getHelmet() {
+        return this.getItem(HELMET_SLOT);
+    }
+
+    @Override
+    public @Nullable ItemStack getChestplate() {
+        return this.getItem(CHESTPLATE_SLOT);
+    }
+
+    @Override
+    public @Nullable ItemStack getLeggings() {
+        return this.getItem(LEGGINGS_SLOT);
+    }
+
+    @Override
+    public @Nullable ItemStack getBoots() {
+        return this.getItem(BOOTS_SLOT);
+    }
+
+    private int slot(EquipmentSlot equipmentSlot) {
+        return switch (equipmentSlot) {
+            case HAND -> this.getHeldItemSlot();
+            case OFF_HAND -> OFF_HAND_SLOT;
+            case FEET -> BOOTS_SLOT;
+            case LEGS -> LEGGINGS_SLOT;
+            case CHEST -> CHESTPLATE_SLOT;
+            case HEAD -> HELMET_SLOT;
+            default -> throw new IllegalArgumentException(
+                "Unsupported player equipment slot: " + equipmentSlot
+            );
+        };
+    }
+
+    @Override
+    public void setItem(EquipmentSlot slot, @Nullable ItemStack item) {
+        this.setItem(this.slot(slot), item);
+    }
+
+    @Override
+    public @Nullable ItemStack getItem(EquipmentSlot slot) {
+        return this.getItem(this.slot(slot));
+    }
+
+    @Override
+    public void setArmorContents(ItemStack[] items) {
+        if (items == null || items.length > 4) {
+            throw new IllegalArgumentException("Armor contents may contain at most 4 items");
+        }
+        this.setBoots(items.length > 0 ? items[0] : null);
+        this.setLeggings(items.length > 1 ? items[1] : null);
+        this.setChestplate(items.length > 2 ? items[2] : null);
+        this.setHelmet(items.length > 3 ? items[3] : null);
+    }
+
+    @Override
+    public void setExtraContents(ItemStack[] items) {
+        if (items == null || items.length > 1) {
+            throw new IllegalArgumentException("Extra contents may contain at most 1 item");
+        }
+        this.setItemInOffHand(items.length == 0 ? null : items[0]);
+    }
+
+    @Override
+    public void setHelmet(@Nullable ItemStack helmet) {
+        this.setItem(HELMET_SLOT, helmet);
+    }
+
+    @Override
+    public void setChestplate(@Nullable ItemStack chestplate) {
+        this.setItem(CHESTPLATE_SLOT, chestplate);
+    }
+
+    @Override
+    public void setLeggings(@Nullable ItemStack leggings) {
+        this.setItem(LEGGINGS_SLOT, leggings);
+    }
+
+    @Override
+    public void setBoots(@Nullable ItemStack boots) {
+        this.setItem(BOOTS_SLOT, boots);
+    }
+
+    @Override
+    public @Nullable ItemStack getItemInMainHand() {
+        return this.getItem(this.getHeldItemSlot());
+    }
+
+    @Override
+    public void setItemInMainHand(@Nullable ItemStack item) {
+        this.setItem(this.getHeldItemSlot(), item);
+    }
+
+    @Override
+    public @Nullable ItemStack getItemInOffHand() {
+        return this.getItem(OFF_HAND_SLOT);
+    }
+
+    @Override
+    public void setItemInOffHand(@Nullable ItemStack item) {
+        this.setItem(OFF_HAND_SLOT, item);
+    }
+
+    @Override
+    public @Nullable ItemStack getItemInHand() {
+        return this.getItemInMainHand();
+    }
+
+    @Override
+    public void setItemInHand(@Nullable ItemStack item) {
+        this.setItemInMainHand(item);
+    }
+
+    @Override
+    public int getHeldItemSlot() {
+        var snapshot = NativeBridgeFfi.getInventory(
+            GetInventoryRequest.newBuilder()
+                .setPlayerUuid(BridgeUtils.convertUuid(this.playerUuid))
+                .setKind(this.kind)
+                .build()
+        );
+        if (snapshot == null || !snapshot.hasHeldItemSlot()) {
+            throw new IllegalStateException(
+                "Failed to read held slot for player " + this.playerUuid
+            );
+        }
+        return snapshot.getHeldItemSlot();
+    }
+
+    @Override
+    public void setHeldItemSlot(int slot) {
+        if (slot < 0 || slot > 8) {
+            throw new IllegalArgumentException("Held item slot must be between 0 and 8");
+        }
+        var response = NativeBridgeFfi.setHeldItemSlot(
+            SetHeldItemSlotRequest.newBuilder()
+                .setPlayerUuid(BridgeUtils.convertUuid(this.playerUuid))
+                .setSlot(slot)
+                .build()
+        );
+        if (response == null || !response.getSuccess()) {
+            throw new IllegalStateException(
+                "Failed to update held slot for player " + this.playerUuid
+            );
+        }
+    }
+
+    @Override
+    public HumanEntity getHolder() {
+        return this.holder;
+    }
+
+    @Override
+    public void setItem(EquipmentSlot slot, @Nullable ItemStack item, boolean silent) {
+        this.setItem(slot, item);
+    }
+
+    @Override
+    public void setItemInMainHand(@Nullable ItemStack item, boolean silent) {
+        this.setItemInMainHand(item);
+    }
+
+    @Override
+    public void setItemInOffHand(@Nullable ItemStack item, boolean silent) {
+        this.setItemInOffHand(item);
+    }
+
+    @Override
+    public void setHelmet(@Nullable ItemStack helmet, boolean silent) {
+        this.setHelmet(helmet);
+    }
+
+    @Override
+    public void setChestplate(@Nullable ItemStack chestplate, boolean silent) {
+        this.setChestplate(chestplate);
+    }
+
+    @Override
+    public void setLeggings(@Nullable ItemStack leggings, boolean silent) {
+        this.setLeggings(leggings);
+    }
+
+    @Override
+    public void setBoots(@Nullable ItemStack boots, boolean silent) {
+        this.setBoots(boots);
+    }
+
+    @Override
+    public void clear() {
+        super.clear();
+    }
+
+    @Override
+    public float getItemInHandDropChance() {
+        return this.getItemInMainHandDropChance();
+    }
+
+    @Override
+    public void setItemInHandDropChance(float chance) {
+        this.setItemInMainHandDropChance(chance);
+    }
+
+    @Override
+    public float getItemInMainHandDropChance() {
+        return this.getDropChance(EquipmentSlot.HAND);
+    }
+
+    @Override
+    public void setItemInMainHandDropChance(float chance) {
+        this.setDropChance(EquipmentSlot.HAND, chance);
+    }
+
+    @Override
+    public float getItemInOffHandDropChance() {
+        return this.getDropChance(EquipmentSlot.OFF_HAND);
+    }
+
+    @Override
+    public void setItemInOffHandDropChance(float chance) {
+        this.setDropChance(EquipmentSlot.OFF_HAND, chance);
+    }
+
+    @Override
+    public float getHelmetDropChance() {
+        return this.getDropChance(EquipmentSlot.HEAD);
+    }
+
+    @Override
+    public void setHelmetDropChance(float chance) {
+        this.setDropChance(EquipmentSlot.HEAD, chance);
+    }
+
+    @Override
+    public float getChestplateDropChance() {
+        return this.getDropChance(EquipmentSlot.CHEST);
+    }
+
+    @Override
+    public void setChestplateDropChance(float chance) {
+        this.setDropChance(EquipmentSlot.CHEST, chance);
+    }
+
+    @Override
+    public float getLeggingsDropChance() {
+        return this.getDropChance(EquipmentSlot.LEGS);
+    }
+
+    @Override
+    public void setLeggingsDropChance(float chance) {
+        this.setDropChance(EquipmentSlot.LEGS, chance);
+    }
+
+    @Override
+    public float getBootsDropChance() {
+        return this.getDropChance(EquipmentSlot.FEET);
+    }
+
+    @Override
+    public void setBootsDropChance(float chance) {
+        this.setDropChance(EquipmentSlot.FEET, chance);
+    }
+
+    @Override
+    public float getDropChance(EquipmentSlot slot) {
+        return this.dropChances.getOrDefault(slot, 1.0f);
+    }
+
+    @Override
+    public void setDropChance(EquipmentSlot slot, float chance) {
+        if (!Float.isFinite(chance) || chance < 0.0f || chance > 1.0f) {
+            throw new IllegalArgumentException("Drop chance must be between 0 and 1");
+        }
+        this.dropChances.put(slot, chance);
+    }
+}
diff --git a/java/patchbukkit/src/main/java/org/patchbukkit/profile/PatchBukkitPlayerProfile.java b/java/patchbukkit/src/main/java/org/patchbukkit/profile/PatchBukkitPlayerProfile.java
new file mode 100644
index 0000000000000000000000000000000000000000..ce9b391693892699a86f614b28635e65a92b1ce4
--- /dev/null
+++ b/java/patchbukkit/src/main/java/org/patchbukkit/profile/PatchBukkitPlayerProfile.java
@@ -0,0 +1,253 @@
+package org.patchbukkit.profile;
+
+import com.destroystokyo.paper.profile.PlayerProfile;
+import com.destroystokyo.paper.profile.ProfileProperty;
+import java.net.URL;
+import java.util.Collection;
+import java.util.LinkedHashMap;
+import java.util.LinkedHashSet;
+import java.util.Map;
+import java.util.Objects;
+import java.util.Set;
+import java.util.UUID;
+import java.util.concurrent.CompletableFuture;
+import org.bukkit.profile.PlayerTextures;
+import org.jetbrains.annotations.NotNull;
+import org.jetbrains.annotations.Nullable;
+
+/**
+ * Lightweight profile used while a client is still in the pre-login phase.
+ *
+ * <p>PatchBukkit does not own Mojang's profile cache yet, so completion methods
+ * report whether the supplied identity is already complete instead of doing
+ * network I/O.</p>
+ */
+public final class PatchBukkitPlayerProfile implements PlayerProfile {
+    private @Nullable UUID id;
+    private @Nullable String name;
+    private PlayerTextures textures;
+    private final Set<ProfileProperty> properties;
+
+    public PatchBukkitPlayerProfile(@Nullable UUID id, @Nullable String name) {
+        if (id == null && (name == null || name.isBlank())) {
+            throw new IllegalArgumentException("A player profile requires a UUID or name");
+        }
+        this.id = id;
+        this.name = name;
+        this.textures = new EmptyPlayerTextures();
+        this.properties = new LinkedHashSet<>();
+    }
+
+    private PatchBukkitPlayerProfile(PatchBukkitPlayerProfile source) {
+        this.id = source.id;
+        this.name = source.name;
+        this.textures = source.textures instanceof EmptyPlayerTextures empty
+            ? new EmptyPlayerTextures(empty)
+            : source.textures;
+        this.properties = new LinkedHashSet<>(source.properties);
+    }
+
+    @Override
+    public @Nullable String getName() {
+        return this.name;
+    }
+
+    @Override
+    public @Nullable String setName(@Nullable String name) {
+        String previous = this.name;
+        this.name = name;
+        return previous;
+    }
+
+    @Override
+    public @Nullable UUID getId() {
+        return this.id;
+    }
+
+    @Override
+    public @Nullable UUID setId(@Nullable UUID id) {
+        UUID previous = this.id;
+        this.id = id;
+        return previous;
+    }
+
+    @Override
+    public @Nullable UUID getUniqueId() {
+        return this.id;
+    }
+
+    @Override
+    public @NotNull PlayerTextures getTextures() {
+        return this.textures;
+    }
+
+    @Override
+    public void setTextures(@Nullable PlayerTextures textures) {
