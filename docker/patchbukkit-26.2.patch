+        if (index < 0 || index > this.size) {
+            throw new IndexOutOfBoundsException("Iterator index: " + index);
+        }
+        List<ItemStack> snapshot = new ArrayList<>(Arrays.asList(this.getContents()));
+        ListIterator<ItemStack> delegate = snapshot.listIterator(index);
+        return new ListIterator<>() {
+            private int lastSlot = -1;
+
+            @Override
+            public boolean hasNext() {
+                return delegate.hasNext();
+            }
+
+            @Override
+            public ItemStack next() {
+                ItemStack item = delegate.next();
+                this.lastSlot = delegate.previousIndex();
+                return item;
+            }
+
+            @Override
+            public boolean hasPrevious() {
+                return delegate.hasPrevious();
+            }
+
+            @Override
+            public ItemStack previous() {
+                ItemStack item = delegate.previous();
+                this.lastSlot = delegate.nextIndex();
+                return item;
+            }
+
+            @Override
+            public int nextIndex() {
+                return delegate.nextIndex();
+            }
+
+            @Override
+            public int previousIndex() {
+                return delegate.previousIndex();
+            }
+
+            @Override
+            public void remove() {
+                if (this.lastSlot < 0) {
+                    throw new IllegalStateException("next or previous must be called first");
+                }
+                PatchBukkitInventory.this.setItem(this.lastSlot, null);
+                delegate.set(null);
+                this.lastSlot = -1;
+            }
+
+            @Override
+            public void set(ItemStack item) {
+                if (this.lastSlot < 0) {
+                    throw new IllegalStateException("next or previous must be called first");
+                }
+                PatchBukkitInventory.this.setItem(this.lastSlot, item);
+                delegate.set(item);
+            }
+
+            @Override
+            public void add(ItemStack item) {
+                throw new UnsupportedOperationException(
+                    "Inventory iterators cannot change the fixed inventory size"
+                );
+            }
+        };
+    }
