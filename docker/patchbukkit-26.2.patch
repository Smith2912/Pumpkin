+    }
+
+    private static PersistentDataContainer emptyPersistentDataContainer() {
+        return (PersistentDataContainer) Proxy.newProxyInstance(
+            PatchBukkitItemMeta.class.getClassLoader(),
+            new Class<?>[] {PersistentDataContainer.class},
+            (proxy, method, args) -> {
+                return switch (method.getName()) {
+                    case "getKeys" -> Set.of();
+                    case "isEmpty" -> true;
+                    case "has" -> false;
+                    case "get" -> null;
+                    case "getOrDefault" -> args[2];
+                    case "equals" -> proxy == args[0];
+                    case "hashCode" -> System.identityHashCode(proxy);
+                    case "toString" -> "PatchBukkitEmptyPersistentDataContainer";
+                    default -> throw unsupported(method);
+                };
+            }
