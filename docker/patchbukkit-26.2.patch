+    private static final LegacyComponentSerializer LEGACY =
+        LegacyComponentSerializer.legacySection();
+    private static final PlainTextComponentSerializer PLAIN =
+        PlainTextComponentSerializer.plainText();
+
+    private final Material material;
+    private Component displayName;
+    private List<Component> lore;
+    private final Map<Enchantment, Integer> enchantments;
+    private final Set<ItemFlag> itemFlags;
+    private Integer damage;
+    private Integer repairCost;
+    private boolean unbreakable;
+
+    private PatchBukkitItemMeta(Material material) {
+        this.material = Objects.requireNonNull(material, "material");
+        this.enchantments = new LinkedHashMap<>();
+        this.itemFlags = EnumSet.noneOf(ItemFlag.class);
+    }
+
+    private PatchBukkitItemMeta(PatchBukkitItemMeta source) {
+        this.material = source.material;
+        this.displayName = source.displayName;
+        this.lore = source.lore == null ? null : new ArrayList<>(source.lore);
+        this.enchantments = new LinkedHashMap<>(source.enchantments);
+        this.itemFlags = source.itemFlags.isEmpty()
+            ? EnumSet.noneOf(ItemFlag.class)
+            : EnumSet.copyOf(source.itemFlags);
+        this.damage = source.damage;
+        this.repairCost = source.repairCost;
+        this.unbreakable = source.unbreakable;
+    }
+
