+pub fn ffi_native_bridge_update_player_presentation_impl(
+    request: UpdatePlayerPresentationRequest,
+) -> Option<bool> {
+    let ctx = CALLBACK_CONTEXT.get()?;
+    let player_uuid = uuid::Uuid::parse_str(&request.player_uuid?.value).ok()?;
+    let player = ctx.plugin_context.server.get_player_by_uuid(player_uuid)?;
+    let display_name = match request.display_name {
+        Some(component) => Some(deserialize_nullable_component(component)?),
+        None => None,
+    };
+    let player_list_name = match request.player_list_name {
+        Some(component) => Some(deserialize_nullable_component(component)?),
+        None => None,
+    };
+    let header = match request.player_list_header_json {
+        Some(json) => Some(serde_json::from_str::<TextComponent>(&json).ok()?),
+        None => None,
+    };
+    let footer = match request.player_list_footer_json {
+        Some(json) => Some(serde_json::from_str::<TextComponent>(&json).ok()?),
+        None => None,
+    };
+    if request.player_list_order.is_some_and(|order| order < 0) {
+        return Some(false);
+    }
+
+    tokio::task::block_in_place(|| {
+        ctx.runtime.block_on(async {
+            if let Some(display_name) = display_name {
+                player.set_display_name(display_name).await;
+            }
+            if let Some(player_list_name) = player_list_name {
+                player.set_tab_list_name(player_list_name).await;
+            }
+            if header.is_some() || footer.is_some() {
+                let resolved_header = match header {
+                    Some(header) => header,
+                    None => player.tab_list_header.lock().await.clone(),
+                };
+                let resolved_footer = match footer {
+                    Some(footer) => footer,
+                    None => player.tab_list_footer.lock().await.clone(),
+                };
+                player
+                    .set_tab_list_header_footer(resolved_header, resolved_footer)
+                    .await;
+            }
+            if let Some(order) = request.player_list_order {
+                player.set_tab_list_order(order);
+            }
+        })
+    });
+
+    Some(true)
+}
