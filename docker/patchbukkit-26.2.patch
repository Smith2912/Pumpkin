+        if (metadata.hasDisplayName()) {
+            state.displayName = Component.text(metadata.getDisplayName());
+        }
+        if (!metadata.getLoreList().isEmpty()) {
+            state.lore = metadata.getLoreList().stream()
+                .map(line -> (Component) Component.text(line))
+                .toList();
+        }
+        metadata.getEnchantmentsMap().forEach((name, level) -> {
