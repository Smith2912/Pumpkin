--- /dev/null
+++ b/java/patchbukkit/src/main/java/org/bukkit/craftbukkit/CraftServer.java
@@ -0,0 +1,16 @@
+package org.bukkit.craftbukkit;
+
+/**
+ * Modern CraftBukkit-compatible server identity.
+ *
+ * Many Bukkit plugins use the runtime server class to select their provider
+ * implementation. Keeping the public server in this package lets those
+ * plugins recognize PatchBukkit as a modern, Mojang-mapped Bukkit runtime
+ * while the implementation remains in {@code org.patchbukkit}.
+ */
+public final class CraftServer extends org.patchbukkit.PatchBukkitServer {
+
+    public CraftServer() {
+        super();
+    }
+}
