@@ -0,0 +1,152 @@
+use std::str::FromStr;
+
+use pumpkin_util::{GameMode, math::vector3::Vector3};
+
+use crate::java::native_callbacks::CALLBACK_CONTEXT;
+use crate::proto::patchbukkit::{
+    common::Uuid,
+    player::{
+        PlayerGameMode, PlayerVitals, SetPlayerGameModeRequest, TeleportPlayerRequest,
+        UpdatePlayerVitalsRequest,
+    },
+};
+
+pub fn ffi_native_bridge_get_player_game_mode_impl(request: Uuid) -> Option<PlayerGameMode> {
+    let ctx = CALLBACK_CONTEXT.get()?;
+    let player_uuid = uuid::Uuid::parse_str(&request.value).ok()?;
+    let player = ctx.plugin_context.server.get_player_by_uuid(player_uuid)?;
+
+    Some(PlayerGameMode {
+        current: player.gamemode.load().name().to_owned(),
+        previous: player
+            .previous_gamemode
+            .load()
+            .map(|game_mode| game_mode.name().to_owned()),
+    })
+}
+
+pub fn ffi_native_bridge_set_player_game_mode_impl(
+    request: SetPlayerGameModeRequest,
+) -> Option<bool> {
+    let ctx = CALLBACK_CONTEXT.get()?;
+    let player_uuid = uuid::Uuid::parse_str(&request.player_uuid?.value).ok()?;
+    let game_mode = GameMode::from_str(&request.game_mode.to_ascii_lowercase()).ok()?;
+    let player = ctx.plugin_context.server.get_player_by_uuid(player_uuid)?;
+
+    tokio::task::block_in_place(|| {
+        ctx.runtime
+            .block_on(player.apply_gamemode_after_external_event(game_mode));
+    });
+
+    Some(true)
+}
+
+pub fn ffi_native_bridge_get_player_vitals_impl(request: Uuid) -> Option<PlayerVitals> {
+    let ctx = CALLBACK_CONTEXT.get()?;
+    let player_uuid = uuid::Uuid::parse_str(&request.value).ok()?;
+    let player = ctx.plugin_context.server.get_player_by_uuid(player_uuid)?;
+
+    Some(PlayerVitals {
+        health: f64::from(player.living_entity.health.load()),
+        max_health: f64::from(player.living_entity.get_max_health()),
+        absorption: f64::from(player.get_absorption()),
+        food_level: i32::from(player.hunger_manager.level.load()),
+        saturation: player.hunger_manager.saturation.load(),
+        exhaustion: player.get_exhaustion(),
+    })
+}
+
+pub fn ffi_native_bridge_update_player_vitals_impl(
+    request: UpdatePlayerVitalsRequest,
+) -> Option<bool> {
+    let ctx = CALLBACK_CONTEXT.get()?;
+    let player_uuid = uuid::Uuid::parse_str(&request.player_uuid?.value).ok()?;
+    let player = ctx.plugin_context.server.get_player_by_uuid(player_uuid)?;
+    let numeric_limit = f64::from(f32::MAX);
+    let target_max_health = request
+        .max_health
+        .unwrap_or_else(|| f64::from(player.living_entity.get_max_health()));
+
+    if request.health.is_some_and(|value| {
+        !value.is_finite() || value < 0.0 || value > numeric_limit || value > target_max_health
+    }) || request
+        .max_health
+        .is_some_and(|value| !value.is_finite() || value <= 0.0 || value > numeric_limit)
+        || request
+            .absorption
+            .is_some_and(|value| !value.is_finite() || value < 0.0 || value > numeric_limit)
+        || request
+            .food_level
+            .is_some_and(|value| !(0..=20).contains(&value))
+        || request
+            .saturation
+            .is_some_and(|value| !value.is_finite() || value < 0.0)
+        || request
+            .exhaustion
+            .is_some_and(|value| !value.is_finite() || value < 0.0)
+    {
+        return Some(false);
+    }
+
+    tokio::task::block_in_place(|| {
+        ctx.runtime.block_on(async {
+            if let Some(max_health) = request.max_health {
+                player.set_max_health(max_health as f32).await;
+            }
+            if let Some(health) = request.health {
+                player.set_health(health as f32).await;
+            }
+            if let Some(absorption) = request.absorption {
+                player.set_absorption(absorption as f32).await;
+            }
+            if let Some(food_level) = request.food_level {
+                player.set_food_level(food_level as u8).await;
+            }
+            if let Some(saturation) = request.saturation {
+                player.set_saturation(saturation).await;
+            }
+            if let Some(exhaustion) = request.exhaustion {
+                player.set_exhaustion(exhaustion).await;
+            }
+        })
+    });
+
+    Some(true)
+}
+
+pub fn ffi_native_bridge_teleport_player_impl(request: TeleportPlayerRequest) -> Option<bool> {
+    let ctx = CALLBACK_CONTEXT.get()?;
+    let player_uuid = uuid::Uuid::parse_str(&request.player_uuid?.value).ok()?;
+    let destination = request.destination?;
+    let world_uuid = uuid::Uuid::parse_str(&destination.world?.uuid?.value).ok()?;
+    let position = destination.position?;
+
+    if !position.x.is_finite()
+        || !position.y.is_finite()
+        || !position.z.is_finite()
+        || !destination.yaw.is_finite()
+        || !destination.pitch.is_finite()
+    {
+        return Some(false);
+    }
+
+    let player = ctx.plugin_context.server.get_player_by_uuid(player_uuid)?;
+    let worlds = ctx.plugin_context.server.worlds.load();
+    let world = worlds
+        .iter()
+        .find(|candidate| candidate.uuid == world_uuid)
+        .cloned()?;
+    drop(worlds);
+
+    let success = tokio::task::block_in_place(|| {
+        ctx.runtime
+            .block_on(player.apply_teleport_after_external_event(
+                Vector3::new(position.x, position.y, position.z),
+                destination.yaw,
+                destination.pitch,
+                world,
+            ))
+    });
+
+    Some(success)
+}
