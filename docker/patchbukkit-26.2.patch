+async fn forward_event_to_jvm<E: PatchBukkitEvent>(
+    plugin_name: &str,
+    command_tx: &mpsc::Sender<JvmCommand>,
+    server: &Arc<Server>,
+    event: &mut E,
+) -> Option<bool> {
+    let (tx, rx) = oneshot::channel();
+    if let Err(e) = command_tx
+        .send(JvmCommand::FireEvent {
+            payload: event.to_payload(server.clone()),
+            respond_to: tx,
+            plugin: plugin_name.to_owned(),
+        })
+        .await
+    {
+        tracing::error!("Failed to send event to JVM worker: {e}");
+        return None;
+    }
+
+    match rx.await {
+        Ok(response) => {
+            let cancelled = response.cancelled;
+            event.apply_modifications(server, response.data?.data?);
+            Some(cancelled)
+        }
+        Err(_) => {
+            tracing::warn!("JVM worker dropped response channel for event");
+            None
+        }
+    }
+}
