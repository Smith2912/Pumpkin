+package org.patchbukkit.world;
+
+import java.lang.reflect.InvocationHandler;
+import java.lang.reflect.Method;
+import java.lang.reflect.Proxy;
+import java.util.List;
+import java.util.Map;
+import java.util.Objects;
+import java.util.concurrent.ConcurrentHashMap;
+import org.bukkit.Location;
+import org.bukkit.Material;
+import org.bukkit.block.Block;
+import org.bukkit.block.BlockFace;
+import org.bukkit.metadata.MetadataValue;
+import org.bukkit.plugin.Plugin;
+import patchbukkit.bridge.NativeBridgeFfi;
+import patchbukkit.common.BlockPosition;
+import patchbukkit.common.BlockSnapshot;
+import patchbukkit.common.UUID;
+
+/**
+ * Read-only Bukkit block view backed by Pumpkin's live world state.
+ *
+ * <p>The event bridge can seed the material captured by the native event. Blocks obtained
+ * through {@link org.bukkit.World#getBlockAt(int, int, int)} resolve their material lazily
+ * through the native bridge. Mutating methods fail explicitly until a write-through world
+ * contract is implemented.</p>
+ */
+public final class PatchBukkitBlock implements InvocationHandler {
+    private final PatchBukkitWorld world;
+    private final int x;
+    private final int y;
+    private final int z;
+    private final Map<String, List<MetadataValue>> metadata = new ConcurrentHashMap<>();
+    private volatile Material material;
+
+    private PatchBukkitBlock(
+        PatchBukkitWorld world,
+        int x,
+        int y,
+        int z,
+        Material material
+    ) {
+        this.world = Objects.requireNonNull(world, "world");
+        this.x = x;
+        this.y = y;
+        this.z = z;
+        this.material = material;
+    }
+
+    public static Block create(PatchBukkitWorld world, int x, int y, int z) {
+        return create(world, x, y, z, null);
+    }
+
+    public static Block create(
+        PatchBukkitWorld world,
+        int x,
+        int y,
+        int z,
+        String materialKey
+    ) {
+        Material material = materialKey == null
+            ? null
+            : requireMaterial(materialKey);
+        PatchBukkitBlock handler = new PatchBukkitBlock(world, x, y, z, material);
+        return (Block) Proxy.newProxyInstance(
+            Block.class.getClassLoader(),
+            new Class<?>[] { Block.class },
+            handler
+        );
+    }
+
+    @Override
+    public Object invoke(Object proxy, Method method, Object[] arguments) {
+        Object[] args = arguments == null ? new Object[0] : arguments;
+        return switch (method.getName()) {
+            case "getWorld" -> world;
+            case "getX" -> x;
+            case "getY" -> y;
+            case "getZ" -> z;
+            case "getType" -> getMaterial();
+            case "getBlockData" -> getMaterial().createBlockData();
+            case "getData", "getLightLevel", "getLightFromSky", "getLightFromBlocks" ->
+                (byte) 0;
+            case "getLocation" -> getLocation(args);
+            case "getRelative" -> getRelative(args);
+            case "getFace" -> getFace((Block) args[0]);
+            case "isEmpty" -> getMaterial().isAir();
+            case "isLiquid" -> getMaterial() == Material.WATER || getMaterial() == Material.LAVA;
+            case "isBuildable", "isSolid", "isCollidable" -> getMaterial().isSolid();
+            case "isBurnable" -> getMaterial().isBurnable();
+            case "isReplaceable" -> getMaterial().isAir()
+                || getMaterial() == Material.WATER
+                || getMaterial() == Material.LAVA;
+            case "getTranslationKey" -> getMaterial().translationKey();
+            case "hasMetadata" -> metadata.containsKey((String) args[0]);
+            case "getMetadata" -> metadata.getOrDefault((String) args[0], List.of());
+            case "setMetadata" -> setMetadata((String) args[0], (MetadataValue) args[1]);
+            case "removeMetadata" -> removeMetadata((String) args[0], (Plugin) args[1]);
+            case "hashCode" -> Objects.hash(world.getUID(), x, y, z);
+            case "equals" -> equalsBlock(proxy, args[0]);
+            case "toString" -> "PatchBukkitBlock{"
+                + world.getName() + ":" + x + "," + y + "," + z
+                + " " + getMaterial() + "}";
+            default -> throw new UnsupportedOperationException(
+                "Block method '" + method.getName()
+                    + "' requires a native write or data contract that PatchBukkit does not yet expose"
+            );
+        };
+    }
+
+    private Material getMaterial() {
+        Material current = material;
+        if (current != null) {
+            return current;
+        }
+
+        BlockSnapshot snapshot = NativeBridgeFfi.getBlock(
+            BlockPosition.newBuilder()
+                .setWorldUuid(UUID.newBuilder().setValue(world.getUID().toString()).build())
+                .setX(x)
+                .setY(y)
+                .setZ(z)
+                .build()
+        );
+        current = requireMaterial(snapshot.getMaterialKey());
+        material = current;
+        return current;
+    }
+
+    private Object getLocation(Object[] args) {
+        if (args.length == 0) {
+            return new Location(world, x, y, z);
+        }
+        Location location = (Location) args[0];
+        if (location == null) {
+            return null;
+        }
+        location.setWorld(world);
+        location.setX(x);
+        location.setY(y);
+        location.setZ(z);
+        location.setYaw(0);
+        location.setPitch(0);
+        return location;
+    }
+
+    private Block getRelative(Object[] args) {
+        if (args[0] instanceof BlockFace face) {
+            int distance = args.length == 1 ? 1 : (int) args[1];
+            return create(
+                world,
+                x + face.getModX() * distance,
+                y + face.getModY() * distance,
+                z + face.getModZ() * distance
+            );
+        }
+        return create(
+            world,
+            x + (int) args[0],
+            y + (int) args[1],
+            z + (int) args[2]
+        );
+    }
+
+    private BlockFace getFace(Block other) {
+        if (other == null || !world.equals(other.getWorld())) {
+            return null;
+        }
+        int dx = other.getX() - x;
+        int dy = other.getY() - y;
+        int dz = other.getZ() - z;
+        for (BlockFace face : BlockFace.values()) {
+            if (face.getModX() == dx && face.getModY() == dy && face.getModZ() == dz) {
+                return face;
+            }
+        }
+        return null;
+    }
+
+    private Object setMetadata(String key, MetadataValue value) {
+        metadata.compute(key, (ignored, existing) -> {
+            List<MetadataValue> values = existing == null
+                ? new java.util.ArrayList<>()
+                : new java.util.ArrayList<>(existing);
+            values.removeIf(old -> old.getOwningPlugin() == value.getOwningPlugin());
+            values.add(value);
+            return List.copyOf(values);
+        });
+        return null;
+    }
+
+    private Object removeMetadata(String key, Plugin owner) {
+        metadata.computeIfPresent(key, (ignored, existing) -> {
+            List<MetadataValue> values = existing.stream()
+                .filter(value -> value.getOwningPlugin() != owner)
+                .toList();
+            return values.isEmpty() ? null : values;
+        });
+        return null;
+    }
+
+    private boolean equalsBlock(Object proxy, Object other) {
+        if (proxy == other) {
+            return true;
+        }
+        if (!(other instanceof Block block)) {
+            return false;
+        }
+        return world.equals(block.getWorld())
+            && x == block.getX()
+            && y == block.getY()
+            && z == block.getZ();
+    }
+
+    private static Material requireMaterial(String key) {
+        Material result = Material.matchMaterial(key);
+        if (result == null) {
+            throw new IllegalArgumentException("Unknown Pumpkin block material: " + key);
+        }
+        return result;
+    }
+}
