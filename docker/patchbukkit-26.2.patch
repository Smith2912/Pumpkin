+        if (first instanceof PatchBukkitItemStack nativeItem) {
+            return nativeItem.bridgeSimilar(second);
+        }
+        if (second instanceof PatchBukkitItemStack nativeItem) {
+            return nativeItem.bridgeSimilar(first);
+        }
+        return first.getType() == second.getType()
+            && !first.hasItemMeta()
+            && !second.hasItemMeta();
+    }
