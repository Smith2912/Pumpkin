+                .setPlayerUuid(BridgeUtils.convertUuid(this.playerUuid))
+                .setKind(this.kind)
+                .build()
+        );
+        if (snapshot == null || snapshot.getContentsCount() != this.size) {
+            throw new IllegalStateException(
