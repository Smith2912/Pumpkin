+            result.put("lore", this.lore.stream().map(LEGACY::serialize).toList());
+        }
+        if (!this.enchantments.isEmpty()) {
+            Map<String, Integer> serializedEnchantments = new LinkedHashMap<>();
+            this.enchantments.forEach((enchantment, level) ->
