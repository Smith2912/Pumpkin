+    fn add_spigot_plugin(manager: &mut PluginManager, name: &str, dependencies: &[&str]) {
+        let dependency_line = if dependencies.is_empty() {
+            String::new()
+        } else {
+            format!("\ndepend: [{}]", dependencies.join(", "))
+        };
+        let config =
+            format!("name: {name}\nversion: 1.0.0\nmain: example.{name}{dependency_line}\n");
+        manager
+            .load_spigot_plugin(PathBuf::from(format!("{name}.jar")), &config)
+            .expect("load test plugin metadata");
+    }
+
+    #[test]
+    fn spigot_dependencies_control_load_order_and_class_visibility() {
+        let mut manager = PluginManager::new();
+        add_spigot_plugin(&mut manager, "CorePlugin", &[]);
+        add_spigot_plugin(&mut manager, "AddonPlugin", &["CorePlugin"]);
+
+        let order = manager.compute_load_order();
+        let core_position = order
+            .iter()
+            .position(|name| name == "coreplugin")
+            .expect("core plugin in load order");
+        let addon_position = order
+            .iter()
+            .position(|name| name == "addonplugin")
+            .expect("addon plugin in load order");
+        assert!(core_position < addon_position);
+
+        let addon = manager
+            .plugins
+            .get("addonplugin")
+            .expect("addon plugin metadata");
+        assert_eq!(manager.dependency_string_for(addon), "CorePlugin");
+    }
+
+    #[test]
