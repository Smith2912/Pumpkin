+public final class PatchBukkitItemFactory {
+    private static final ItemFactory INSTANCE = (ItemFactory) Proxy.newProxyInstance(
+        PatchBukkitItemFactory.class.getClassLoader(),
+        new Class<?>[] {ItemFactory.class},
+        PatchBukkitItemFactory::invoke
+    );
+
+    private PatchBukkitItemFactory() {}
+
+    public static ItemFactory instance() {
+        return INSTANCE;
+    }
+
+    private static Object invoke(Object proxy, Method method, Object[] arguments) {
+        Object[] args = arguments == null ? new Object[0] : arguments;
+        return switch (method.getName()) {
+            case "getItemMeta" ->
+                PatchBukkitItemMeta.empty(Objects.requireNonNull((Material) args[0]));
+            case "isApplicable" -> args[0] instanceof ItemMeta meta
+                && PatchBukkitItemMeta.owns(meta);
+            case "equals" -> Objects.equals(args[0], args[1]);
+            case "asMetaFor" -> {
