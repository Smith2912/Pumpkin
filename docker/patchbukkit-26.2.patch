+fn build_tag_registry(registry_key: PumpkinRegistryKey) -> Registry {
+    let tags = get_registry_key_tags(BUKKIT_API_MINECRAFT_VERSION, registry_key)
+        .map(|tag_map| {
+            tag_map
+                .entries()
+                .map(|(name, tag)| RegistryTagData {
+                    name: (*name).to_string(),
+                    values: tag.0.iter().map(|value| (*value).to_string()).collect(),
+                })
+                .collect()
+        })
+        .unwrap_or_default();
+
+    Registry::TagRegistry(TagRegistryData { tags })
+}
