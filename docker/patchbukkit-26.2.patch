+fn build_item_registry() -> Registry {
+    let items = (0..=u16::MAX)
+        .filter_map(Item::from_id)
+        .map(|item| {
+            let max_stack_size = item
+                .components
+                .iter()
+                .find_map(|(kind, value)| {
+                    (*kind == DataComponent::MaxStackSize)
+                        .then(|| get::<MaxStackSizeImpl>(*value).size)
+                })
+                .unwrap_or(64);
+            let max_durability = item
+                .components
+                .iter()
+                .find_map(|(kind, value)| {
+                    (*kind == DataComponent::MaxDamage)
+                        .then(|| get::<MaxDamageImpl>(*value).max_damage)
+                })
+                .unwrap_or(0);
+            let translation_key = item
+                .components
+                .iter()
+                .find_map(|(kind, value)| {
+                    (*kind == DataComponent::ItemName).then(|| get::<ItemNameImpl>(*value).name)
+                })
+                .unwrap_or("item.minecraft.air");
+
+            ItemData {
+                id: u32::from(item.id),
+                name: item.registry_key.to_owned(),
+                translation_key: translation_key.to_owned(),
+                max_stack_size: u32::from(max_stack_size),
+                max_durability: u32::try_from(max_durability).unwrap_or_default(),
+                edible: item
+                    .components
+                    .iter()
+                    .any(|(kind, _)| *kind == DataComponent::Food),
+                record: item
+                    .components
+                    .iter()
+                    .any(|(kind, _)| *kind == DataComponent::JukeboxPlayable),
+                has_block_type: Block::from_registry_key(item.registry_key).is_some(),
+            }
+        })
+        .collect();
+    Registry::Item(ItemRegistryData { items })
+}
