new file mode 100644
index 0000000000000000000000000000000000000000..a37c488374f50a27c1775d0acd164f99aa2f8810
--- /dev/null
+++ b/rust/src/java/native_callbacks/block.rs
@@ -0,0 +1,20 @@
+use pumpkin_util::math::position::BlockPos;
+use pumpkin_util::math::vector3::Vector3;
+
+use crate::java::native_callbacks::CALLBACK_CONTEXT;
+use crate::proto::patchbukkit::common::{BlockPosition, BlockSnapshot};
+
+pub fn ffi_native_bridge_get_block_impl(position: BlockPosition) -> Option<BlockSnapshot> {
+    let ctx = CALLBACK_CONTEXT.get()?;
+    let world_uuid = uuid::Uuid::parse_str(&position.world_uuid.as_ref()?.value).ok()?;
+    let worlds = ctx.plugin_context.server.worlds.load();
+    let world = worlds.iter().find(|world| world.uuid == world_uuid)?;
+    let block_position = BlockPos(Vector3::new(position.x, position.y, position.z));
+    let (block, state) = world.get_block_and_state(&block_position);
+
+    Some(BlockSnapshot {
+        position: Some(position),
+        material_key: format!("minecraft:{}", block.name),
+        state_id: u32::from(state.id.as_u16()),
+    })
+}
