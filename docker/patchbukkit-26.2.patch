index 0000000..735217e
--- /dev/null
+++ b/java/patchbukkit/src/main/java/org/bukkit/plugin/SimplePluginManager.java
@@ -0,0 +1,214 @@
+package org.bukkit.plugin;
+
+import io.papermc.paper.plugin.PermissionManager;
+import java.util.HashMap;
+import java.util.HashSet;
+import java.util.LinkedHashMap;
+import java.util.LinkedHashSet;
+import java.util.List;
+import java.util.Locale;
+import java.util.Map;
+import java.util.Set;
+import java.util.WeakHashMap;
+import org.bukkit.Server;
+import org.bukkit.command.SimpleCommandMap;
+import org.bukkit.permissions.Permissible;
+import org.bukkit.permissions.Permission;
+import org.bukkit.permissions.PermissionDefault;
+import org.jetbrains.annotations.NotNull;
+import org.jetbrains.annotations.Nullable;
+
+/**
+ * PatchBukkit-compatible implementation base for Bukkit's standard plugin manager.
+ *
+ * <p>The Paper API ships this class as part of the API jar, but compatibility
+ * plugins such as LuckPerms require the runtime plugin manager to be an instance
+ * of it and replace its public permission maps. PatchBukkit supplies this
+ * source-level implementation so its bridge manager can extend the expected
+ * Bukkit type while retaining its native event integration.</p>
+ */
+@SuppressWarnings("removal")
+public abstract class SimplePluginManager implements PluginManager {
+    protected final Server server;
+    protected final SimpleCommandMap commandMap;
+
+    public Map<String, Permission> permissions = new HashMap<>();
+    public Map<Boolean, Set<Permission>> defaultPerms = new LinkedHashMap<>();
+    public Map<String, Map<Permissible, Boolean>> permSubs = new HashMap<>();
+    public Map<Boolean, Map<Permissible, Boolean>> defSubs = new HashMap<>();
+
+    private boolean useTimings;
+
+    protected SimplePluginManager(Server server, SimpleCommandMap commandMap) {
+        this.server = server;
+        this.commandMap = commandMap;
+        this.defaultPerms.put(true, new LinkedHashSet<>());
+        this.defaultPerms.put(false, new LinkedHashSet<>());
+    }
+
+    @Override
+    public @Nullable Permission getPermission(@NotNull String name) {
+        return this.permissions.get(name.toLowerCase(Locale.ENGLISH));
+    }
+
+    @Override
+    public void addPermission(@NotNull Permission permission) {
+        addPermission(permission, true);
+    }
+
+    @Override
+    public void addPermissions(@NotNull List<Permission> permissions) {
