+            throw new IllegalArgumentException(
+                "Expected at most " + this.size + " items, got " + items.length
+            );
+        }
+        for (int slot = 0; slot < this.size; slot++) {
+            this.setItem(slot, slot < items.length ? items[slot] : null);
+        }
+    }
+
+    @Override
+    public ItemStack[] getStorageContents() {
+        int[] slots = this.storageSlots();
+        ItemStack[] contents = this.getContents();
+        ItemStack[] result = new ItemStack[slots.length];
+        for (int index = 0; index < slots.length; index++) {
