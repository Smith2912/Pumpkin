+impl PatchBukkitEvent for pumpkin::plugin::player::player_teleport::PlayerTeleportEvent {
+    fn to_payload(&self, server: Arc<Server>) -> JvmEventPayload {
+        let entity = &self.player.living_entity.entity;
+        let from_yaw = self.from_yaw.unwrap_or_else(|| entity.yaw.load());
+        let from_pitch = self.from_pitch.unwrap_or_else(|| entity.pitch.load());
+        let to_yaw = self.to_yaw.unwrap_or(from_yaw);
+        let to_pitch = self.to_pitch.unwrap_or(from_pitch);
+        let cause = teleport_cause_name(self.cause);
+        let world_uuid = self.player.world().uuid;
+
+        JvmEventPayload {
+            event: Event {
+                data: Some(Data::PlayerTeleport(ProtoPlayerTeleportEvent {
+                    player_uuid: Some(Uuid {
+                        value: self.player.gameprofile.id.to_string(),
+                    }),
+                    from: Some(location_reference(
+                        world_uuid, self.from, from_yaw, from_pitch,
+                    )),
+                    to: Some(location_reference(world_uuid, self.to, to_yaw, to_pitch)),
+                    cause: cause.to_owned(),
+                })),
+            },
+            context: EventContext {
+                server,
+                player: Some(self.player.clone()),
+            },
+        }
+    }
+
+    fn apply_modifications(&mut self, server: &Arc<Server>, data: Data) -> Option<()> {
+        let Data::PlayerTeleport(event) = data else {
+            return None;
+        };
+        let player_uuid = uuid::Uuid::from_str(&event.player_uuid?.value).ok()?;
+        if player_uuid != self.player.gameprofile.id {
+            return None;
+        }
+        server.get_player_by_uuid(player_uuid)?;
+
+        let from = event.from?;
+        let from_world_uuid = uuid::Uuid::from_str(&from.world?.uuid?.value).ok()?;
+        let from_position = from.position?;
+        let to = event.to?;
+        let to_world_uuid = uuid::Uuid::from_str(&to.world?.uuid?.value).ok()?;
+        let to_position = to.position?;
+        let expected_world_uuid = self.player.world().uuid;
+        let expected_from_yaw = self
+            .from_yaw
+            .unwrap_or_else(|| self.player.living_entity.entity.yaw.load());
+        let expected_from_pitch = self
+            .from_pitch
+            .unwrap_or_else(|| self.player.living_entity.entity.pitch.load());
+
+        if from_world_uuid != expected_world_uuid
+            || to_world_uuid != expected_world_uuid
+            || from_position.x != self.from.x
+            || from_position.y != self.from.y
+            || from_position.z != self.from.z
+            || from.yaw != expected_from_yaw
+            || from.pitch != expected_from_pitch
+            || event.cause != teleport_cause_name(self.cause)
+            || !to_position.x.is_finite()
+            || !to_position.y.is_finite()
+            || !to_position.z.is_finite()
+            || !to.yaw.is_finite()
+            || !to.pitch.is_finite()
+        {
+            return None;
+        }
+
+        self.to =
+            pumpkin_util::math::vector3::Vector3::new(to_position.x, to_position.y, to_position.z);
+        self.to_yaw = Some(to.yaw);
+        self.to_pitch = Some(to.pitch);
+        Some(())
+    }
+}
