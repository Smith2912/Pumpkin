+pub fn ffi_native_bridge_perform_player_command_impl(
+    request: PerformPlayerCommandRequest,
+) -> Option<bool> {
+    let ctx = CALLBACK_CONTEXT.get()?;
+    let player_uuid = uuid::Uuid::parse_str(&request.player_uuid?.value).ok()?;
+    let command = request.command.trim().to_owned();
+    if command.is_empty() {
+        return Some(false);
+    }
+    let player = ctx.plugin_context.server.get_player_by_uuid(player_uuid)?;
+    let server = ctx.plugin_context.server.clone();
+    let root = command
+        .strip_prefix('/')
+        .unwrap_or(&command)
+        .split_whitespace()
+        .next()?;
+    let command_exists = tokio::task::block_in_place(|| {
+        ctx.runtime.block_on(async {
+            server
+                .command_dispatcher
+                .read()
+                .await
+                .get_all_commands()
+                .contains_key(root)
+        })
+    });
+    if !command_exists {
+        return Some(false);
+    }
+
+    ctx.runtime.spawn(async move {
+        let source = player.get_command_source(&server).await;
+        let dispatcher = server.command_dispatcher.read().await;
+        dispatcher.handle_command(&source, &command).await;
+    });
+
+    Some(true)
+}
