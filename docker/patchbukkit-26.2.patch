+        if (subscribers == null) {
+            return;
+        }
+
+        subscribers.remove(permissible);
+        if (subscribers.isEmpty()) {
+            this.permSubs.remove(name);
+        }
+    }
+
+    @Override
+    public @NotNull Set<Permissible> getPermissionSubscriptions(@NotNull String permission) {
+        Map<Permissible, Boolean> subscribers =
+            this.permSubs.get(permission.toLowerCase(Locale.ENGLISH));
+        return subscribers == null ? Set.of() : Set.copyOf(subscribers.keySet());
+    }
+
+    @Override
+    public void subscribeToDefaultPerms(boolean op, @NotNull Permissible permissible) {
+        this.defSubs.computeIfAbsent(op, ignored -> new WeakHashMap<>()).put(permissible, true);
+    }
+
+    @Override
+    public void unsubscribeFromDefaultPerms(boolean op, @NotNull Permissible permissible) {
+        Map<Permissible, Boolean> subscribers = this.defSubs.get(op);
+        if (subscribers == null) {
