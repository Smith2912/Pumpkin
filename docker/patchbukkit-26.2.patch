+            converted.displayName = copy.displayName;
+            converted.lore = copy.lore;
+            converted.enchantments.putAll(copy.enchantments);
+            converted.itemFlags.addAll(copy.itemFlags);
+            converted.unbreakable = copy.unbreakable;
+            if (material.getMaxDurability() > 0) {
+                converted.damage = copy.damage;
+                converted.repairCost = copy.repairCost;
+            }
+            return converted.proxy();
+        }
+        return copy.proxy();
+    }
+
+    private ItemMeta proxy() {
+        List<Class<?>> interfaces = new ArrayList<>();
+        interfaces.add(ItemMeta.class);
+        if (this.material.getMaxDurability() > 0) {
