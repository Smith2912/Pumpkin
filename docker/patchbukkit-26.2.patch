diff --git a/rust/src/java/native_callbacks/itemstack.rs b/rust/src/java/native_callbacks/itemstack.rs
index 769e4903b02aad8f116d57f113ca7128c0e575b5..6ded69aa406e4a6da46828b1dc28e719724ddc50 100644
--- a/rust/src/java/native_callbacks/itemstack.rs
+++ b/rust/src/java/native_callbacks/itemstack.rs
@@ -1,5 +1,341 @@
-// pub fn ffi_native_bridge_serialize_item_stack_impl(
-//     request: SerializeItemStackRequest,
-// ) -> Option<SerializeItemStackResponse> {
-//     Some(())
-// }
+use std::{borrow::Cow, collections::HashMap};
+
+use pumpkin_data::{
+    Enchantment,
+    data_component::DataComponent,
+    data_component_impl::{
+        CustomNameImpl, DamageImpl, DataComponentImpl, EnchantmentsImpl, LoreImpl, RepairCostImpl,
+        UnbreakableImpl,
+    },
+    item::Item,
+    item_stack::ItemStack,
+};
+use pumpkin_util::text::TextComponent;
+
+use crate::proto::patchbukkit::itemstack::{
+    ItemMetadata as BridgeItemMetadata, ItemStack as BridgeItemStack,
+};
+
+const MAX_NATIVE_NBT_BYTES: usize = 1024 * 1024;
+
+pub fn serialize_item_stack(stack: &ItemStack) -> Option<BridgeItemStack> {
+    let has_native_components = !stack.patch.is_empty();
+    let mut normalized = stack.clone();
+    if !normalized.is_empty() {
+        normalized.item_count = 1;
+    }
+    let native_nbt = normalized.to_nbt_bytes().ok()?;
+
+    // Native plugins are separate dynamic libraries, so Rust TypeIds for
+    // pumpkin-data components are not shared with the server executable. Read
+    // metadata from an NBT round-trip owned by this library instead of
+    // downcasting component trait objects borrowed from the server.
+    let local_stack = ItemStack::from_nbt_bytes(&native_nbt).ok()??;
+
+    Some(BridgeItemStack {
+        r#type: format!("minecraft:{}", stack.item.registry_key),
+        amount: u32::from(stack.item_count),
+        native_nbt,
+        has_native_components,
+        metadata: Some(serialize_metadata(&local_stack)),
+    })
+}
+
+pub fn deserialize_item_stack(stack: BridgeItemStack) -> Option<ItemStack> {
+    let amount = u8::try_from(stack.amount).ok()?;
+    let requested_type = stack
+        .r#type
+        .strip_prefix("minecraft:")
+        .unwrap_or(&stack.r#type);
+
+    if amount == 0 || requested_type == "air" {
+        return Some(ItemStack::EMPTY.clone());
+    }
+
+    if !stack.native_nbt.is_empty() {
+        if stack.native_nbt.len() > MAX_NATIVE_NBT_BYTES {
+            return None;
+        }
+
+        let mut restored = ItemStack::from_nbt_bytes(&stack.native_nbt).ok()??;
+        if restored.item.registry_key != requested_type {
+            return None;
+        }
+        restored.item_count = amount;
+        if stack
+            .metadata
+            .as_ref()
+            .is_some_and(|metadata| metadata.modified)
+        {
+            apply_metadata(&mut restored, stack.metadata.as_ref()?);
+        }
+        return Some(restored);
+    }
+
+    let mut native = ItemStack::new(amount, Item::from_registry_key(requested_type)?);
+    if stack
+        .metadata
+        .as_ref()
+        .is_some_and(|metadata| metadata.modified)
+    {
+        apply_metadata(&mut native, stack.metadata.as_ref()?);
+    }
+    Some(native)
+}
+
+fn serialize_metadata(stack: &ItemStack) -> BridgeItemMetadata {
+    let display_name = stack
+        .get_data_component::<CustomNameImpl>()
+        .map(|name| name.name.clone().get_text());
+    let lore = stack
+        .get_data_component::<LoreImpl>()
+        .map_or_else(Vec::new, |lore| lore.lines.clone());
+    let enchantments =
+        stack
+            .get_data_component::<EnchantmentsImpl>()
+            .map_or_else(HashMap::new, |enchantments| {
+                enchantments
+                    .enchantment
+                    .iter()
+                    .map(|(enchantment, level)| (enchantment.name.to_owned(), *level))
+                    .collect()
+            });
+    let damage = stack
+        .get_data_component::<DamageImpl>()
+        .map(|damage| damage.damage);
+    let repair_cost = stack
+        .get_data_component::<RepairCostImpl>()
+        .map(|repair_cost| repair_cost.cost);
+
+    BridgeItemMetadata {
+        display_name,
+        lore,
+        enchantments,
+        damage,
+        repair_cost,
+        unbreakable: stack.get_data_component::<UnbreakableImpl>().is_some(),
+        modified: false,
+    }
+}
+
+fn apply_metadata(stack: &mut ItemStack, metadata: &BridgeItemMetadata) {
+    replace_component(
+        stack,
+        DataComponent::CustomName,
+        metadata.display_name.as_ref().map(|display_name| {
+            CustomNameImpl {
+                name: TextComponent::text(display_name.clone()),
+            }
+            .to_dyn()
+        }),
+    );
+    replace_component(
+        stack,
+        DataComponent::Lore,
+        (!metadata.lore.is_empty()).then(|| {
+            LoreImpl {
+                lines: metadata.lore.clone(),
+            }
+            .to_dyn()
+        }),
+    );
+
+    let enchantments = metadata
+        .enchantments
+        .iter()
+        .filter_map(|(name, level)| Some((Enchantment::from_name(name)?, *level)))
+        .collect::<Vec<_>>();
+    replace_component(
+        stack,
+        DataComponent::Enchantments,
+        (!enchantments.is_empty()).then(|| {
+            EnchantmentsImpl {
+                enchantment: Cow::Owned(enchantments),
+            }
+            .to_dyn()
+        }),
+    );
+    replace_component(
+        stack,
+        DataComponent::Damage,
+        metadata.damage.map(|damage| DamageImpl { damage }.to_dyn()),
+    );
+    replace_component(
+        stack,
+        DataComponent::RepairCost,
+        metadata
+            .repair_cost
+            .map(|cost| RepairCostImpl { cost }.to_dyn()),
+    );
+    replace_component(
+        stack,
+        DataComponent::Unbreakable,
+        metadata.unbreakable.then(|| UnbreakableImpl.to_dyn()),
+    );
+}
+
+fn replace_component(
+    stack: &mut ItemStack,
+    id: DataComponent,
+    component: Option<Box<dyn DataComponentImpl>>,
+) {
+    if let Some((_, current)) = stack
+        .patch
+        .iter_mut()
+        .find(|(component_id, _)| *component_id == id)
+    {
+        *current = component;
+    } else {
+        stack.patch.push((id, component));
+    }
+}
+
+#[cfg(test)]
+mod tests {
+    use std::any::Any;
+
+    use pumpkin_data::{
+        Enchantment,
+        data_component::DataComponent,
+        data_component_impl::{
+            CustomNameImpl, DamageImpl, DataComponentImpl, EnchantmentsImpl, LoreImpl,
+            RepairCostImpl, UnbreakableImpl,
+        },
+        item::Item,
+        item_stack::ItemStack,
+    };
+
+    use super::{deserialize_item_stack, serialize_item_stack};
+
+    #[derive(Clone)]
+    struct ForeignUnbreakable;
+
+    impl DataComponentImpl for ForeignUnbreakable {
+        fn equal(&self, other: &dyn DataComponentImpl) -> bool {
+            other.as_any().is::<Self>()
+        }
+
+        fn get_enum() -> DataComponent {
+            DataComponent::Unbreakable
+        }
+
+        fn get_self_enum(&self) -> DataComponent {
+            DataComponent::Unbreakable
+        }
+
+        fn to_dyn(self) -> Box<dyn DataComponentImpl> {
+            Box::new(self)
+        }
+
+        fn clone_dyn(&self) -> Box<dyn DataComponentImpl> {
+            Box::new(self.clone())
+        }
+
+        fn as_any(&self) -> &dyn Any {
+            self
+        }
+
+        fn as_mut_any(&mut self) -> &mut dyn Any {
+            self
+        }
+    }
+
+    #[test]
+    fn bridge_localizes_foreign_component_types_before_metadata_reads() {
+        let mut native = ItemStack::new(1, &Item::CRAFTING_TABLE);
+        native.patch.push((
+            DataComponent::Unbreakable,
+            Some(ForeignUnbreakable.to_dyn()),
+        ));
+
+        let bridge = serialize_item_stack(&native).expect("foreign item should serialize");
+
+        assert_eq!(bridge.r#type, "minecraft:crafting_table");
+        assert!(bridge.has_native_components);
+    }
+
+    #[test]
+    fn bridge_roundtrip_preserves_native_components_and_allows_amount_changes() {
+        let mut native = ItemStack::new(1, &Item::WOODEN_AXE);
+        native
+            .patch
+            .push((DataComponent::Unbreakable, Some(UnbreakableImpl.to_dyn())));
+
+        let mut bridge = serialize_item_stack(&native).expect("item should serialize");
+        bridge.amount = 3;
+        let restored = deserialize_item_stack(bridge).expect("item should restore");
+
+        assert_eq!(restored.item.registry_key, Item::WOODEN_AXE.registry_key);
+        assert_eq!(restored.item_count, 3);
+        assert!(restored.get_data_component::<UnbreakableImpl>().is_some());
+    }
+
+    #[test]
+    fn bridge_rejects_native_snapshot_for_a_different_material() {
+        let native = ItemStack::new(1, &Item::WOODEN_AXE);
+        let mut bridge = serialize_item_stack(&native).expect("item should serialize");
+        bridge.r#type = "minecraft:stone".to_owned();
+
+        assert!(deserialize_item_stack(bridge).is_none());
+    }
+
+    #[test]
+    fn bridge_applies_supported_bukkit_metadata_without_losing_other_components() {
+        let mut native = ItemStack::new(1, &Item::DIAMOND_SWORD);
+        native
+            .patch
+            .push((DataComponent::Unbreakable, Some(UnbreakableImpl.to_dyn())));
+
+        let mut bridge = serialize_item_stack(&native).expect("item should serialize");
+        let metadata = bridge.metadata.as_mut().expect("metadata should exist");
+        metadata.modified = true;
+        metadata.display_name = Some("Public Sword".to_owned());
+        metadata.lore = vec!["First line".to_owned(), "Second line".to_owned()];
+        metadata
+            .enchantments
+            .insert("minecraft:sharpness".to_owned(), 5);
+        metadata.damage = Some(12);
+        metadata.repair_cost = Some(7);
+        metadata.unbreakable = false;
+
+        let restored = deserialize_item_stack(bridge).expect("item should restore");
+
+        assert_eq!(
+            restored
+                .get_data_component::<CustomNameImpl>()
+                .expect("name should be present")
+                .name
+                .clone()
+                .get_text(),
+            "Public Sword"
+        );
+        assert_eq!(
+            restored
+                .get_data_component::<LoreImpl>()
+                .expect("lore should be present")
+                .lines,
+            ["First line", "Second line"]
+        );
+        let enchantments = restored
+            .get_data_component::<EnchantmentsImpl>()
+            .expect("enchantments should be present");
+        assert_eq!(enchantments.enchantment.len(), 1);
+        assert!(enchantments.enchantment[0].0 == &Enchantment::SHARPNESS);
+        assert_eq!(enchantments.enchantment[0].1, 5);
+        assert_eq!(
+            restored
+                .get_data_component::<DamageImpl>()
+                .expect("damage should be present")
+                .damage,
+            12
+        );
+        assert_eq!(
+            restored
+                .get_data_component::<RepairCostImpl>()
+                .expect("repair cost should be present")
+                .cost,
+            7
+        );
+        assert!(restored.get_data_component::<UnbreakableImpl>().is_none());
+    }
+}
