+package org.patchbukkit.inventory;
+
+import java.util.Arrays;
+import java.util.Objects;
+
+import org.bukkit.Material;
+import org.bukkit.inventory.ItemType;
+import org.bukkit.inventory.ItemStack;
+import org.bukkit.inventory.meta.ItemMeta;
+import org.jetbrains.annotations.Nullable;
+
+import com.google.protobuf.ByteString;
+import patchbukkit.itemstack.ItemMetadata;
+
+/**
+ * Bukkit item view that retains Pumpkin's complete native item snapshot.
+ *
+ * <p>The opaque data is returned only while the material still matches the
+ * original native item. Amount changes are applied by the native bridge after
+ * validation, allowing ordinary Bukkit inventory operations to preserve
+ * components they do not understand.</p>
+ */
+public final class PatchBukkitItemStack extends ItemStack {
+    private Material type;
+    private int amount;
+    private final Material nativeType;
+    private byte[] nativeNbt;
+    private boolean nativeComponents;
+    private ItemMeta itemMeta;
+    private boolean metadataModified;
+
+    private PatchBukkitItemStack(
+        Material type,
+        int amount,
+        byte[] nativeNbt,
+        boolean nativeComponents,
+        @Nullable ItemMetadata metadata,
+        boolean metadataModified
+    ) {
+        super();
+        this.type = Objects.requireNonNull(type, "type");
+        if (amount < 0) {
+            throw new IllegalArgumentException("Item amount cannot be negative");
+        }
+        this.amount = amount;
+        this.nativeType = type;
+        this.nativeNbt = nativeNbt.clone();
+        this.nativeComponents = nativeComponents;
+        this.itemMeta = metadata == null
+            ? PatchBukkitItemMeta.empty(type)
+            : PatchBukkitItemMeta.fromBridge(type, metadata);
+        this.metadataModified = metadataModified;
+    }
+
+    public static PatchBukkitItemStack create(Material type, int amount) {
+        return new PatchBukkitItemStack(type, amount, new byte[0], false, null, false);
+    }
+
+    public static PatchBukkitItemStack empty() {
+        return create(Material.AIR, 0);
+    }
+
+    public static @Nullable PatchBukkitItemStack fromBridge(
+        patchbukkit.itemstack.ItemStack item
+    ) {
+        if (item == null || item.getAmount() == 0) {
+            return null;
+        }
+
+        Material material = Material.matchMaterial(item.getType());
+        if (material == null && item.getType().startsWith("minecraft:")) {
+            material = Material.matchMaterial(item.getType().substring("minecraft:".length()));
+        }
+        if (material == null || material == Material.AIR) {
+            return null;
+        }
+
+        return new PatchBukkitItemStack(
+            material,
+            Math.toIntExact(item.getAmount()),
+            item.getNativeNbt().toByteArray(),
+            item.getHasNativeComponents(),
+            item.hasMetadata() ? item.getMetadata() : null,
+            false
+        );
+    }
+
+    public static patchbukkit.itemstack.ItemStack toBridge(@Nullable ItemStack item) {
+        if (item == null || item.getType() == Material.AIR || item.getAmount() <= 0) {
+            return patchbukkit.itemstack.ItemStack.newBuilder()
+                .setType("minecraft:air")
+                .setAmount(0)
+                .build();
+        }
+
+        var builder = patchbukkit.itemstack.ItemStack.newBuilder()
+            .setType(item.getType().getKey().asString())
+            .setAmount(item.getAmount());
+
+        if (item instanceof PatchBukkitItemStack nativeItem
+            && item.getType() == nativeItem.nativeType
+            && nativeItem.nativeNbt.length > 0) {
+            builder.setNativeNbt(ByteString.copyFrom(nativeItem.nativeNbt));
+            builder.setHasNativeComponents(nativeItem.nativeComponents);
+        }
+        if (item instanceof PatchBukkitItemStack nativeItem
+            && nativeItem.metadataModified) {
+            builder.setMetadata(PatchBukkitItemMeta.toBridge(nativeItem.itemMeta));
+        }
+
+        return builder.build();
+    }
+
+    @Override
+    public Material getType() {
+        return this.type;
+    }
+
+    @Override
+    public void setType(Material type) {
+        this.type = Objects.requireNonNull(type, "type");
+        if (type != this.nativeType) {
+            this.nativeNbt = new byte[0];
+            this.nativeComponents = false;
+            this.itemMeta = PatchBukkitItemMeta.empty(type);
+            this.metadataModified = false;
+        }
+    }
+
+    @Override
+    public ItemStack withType(Material type) {
+        Objects.requireNonNull(type, "type");
+        if (type == this.type) {
+            return this.clone();
+        }
+        return create(type, this.amount);
+    }
+
+    @Override
+    public int getAmount() {
+        return this.amount;
+    }
+
+    @Override
+    public void setAmount(int amount) {
+        if (amount < 0) {
+            throw new IllegalArgumentException("Item amount cannot be negative");
+        }
+        this.amount = amount;
+    }
+
+    @Override
+    public int getMaxStackSize() {
+        ItemType itemType = this.type.asItemType();
+        return itemType == null ? 64 : itemType.getMaxStackSize();
+    }
+
+    @Override
+    public boolean isEmpty() {
+        return this.type == Material.AIR || this.amount <= 0;
+    }
+
+    @Override
+    public boolean hasItemMeta() {
+        return this.nativeComponents || !this.itemMeta.serialize().isEmpty();
+    }
+
+    @Override
+    public ItemMeta getItemMeta() {
+        return this.itemMeta.clone();
+    }
+
+    public boolean bridgeSimilar(@Nullable ItemStack other) {
+        if (other == null || this.getType() != other.getType()) {
+            return false;
+        }
+        if (other instanceof PatchBukkitItemStack nativeOther
+            && this.nativeNbt.length > 0
+            && nativeOther.nativeNbt.length > 0) {
+            return Arrays.equals(this.nativeNbt, nativeOther.nativeNbt);
+        }
+        return !this.nativeComponents && !other.hasItemMeta();
+    }
+
+    @Override
+    public boolean setItemMeta(@Nullable ItemMeta itemMeta) {
+        if (itemMeta == null) {
+            this.itemMeta = PatchBukkitItemMeta.empty(this.type);
+            this.metadataModified = true;
+            return true;
+        }
+        if (!PatchBukkitItemMeta.owns(itemMeta)) {
+            return false;
+        }
+        this.itemMeta = PatchBukkitItemMeta.copyFor(itemMeta, this.type);
+        this.metadataModified = true;
+        return true;
+    }
+
+    @Override
+    public boolean isSimilar(ItemStack other) {
+        return this.bridgeSimilar(other);
+    }
+
+    @Override
+    public boolean equals(Object other) {
+        return other instanceof ItemStack item
+            && this.amount == item.getAmount()
+            && this.bridgeSimilar(item);
+    }
+
+    @Override
+    public int hashCode() {
+        int result = Objects.hash(this.type, this.amount);
+        result = 31 * result + Arrays.hashCode(this.nativeNbt);
+        return result;
+    }
+
+    @Override
+    public PatchBukkitItemStack clone() {
+        return new PatchBukkitItemStack(
+            this.getType(),
+            this.getAmount(),
+            this.nativeNbt,
+            this.nativeComponents,
+            this.metadataModified ? PatchBukkitItemMeta.toBridge(this.itemMeta) : null,
+            this.metadataModified
+        );
+    }
+}
