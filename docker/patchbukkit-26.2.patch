+        int[] slots = this.storageSlots();
+
+        for (int inputIndex = 0; inputIndex < items.length; inputIndex++) {
+            ItemStack input = Objects.requireNonNull(items[inputIndex], "item").clone();
+            if (isEmpty(input)) {
+                continue;
+            }
+
+            int remaining = input.getAmount();
+            for (int slot : slots) {
+                ItemStack current = contents[slot];
+                if (!similar(current, input)) {
+                    continue;
