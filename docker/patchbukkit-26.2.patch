+        }
+        if !occupied.contains(&alias) {
+            candidates.push(alias.clone());
+        }
+        candidates.push(format!("{fallback_prefix}:{alias}"));
+    }
+
+    let mut seen = HashSet::new();
+    candidates
+        .into_iter()
+        .filter(|route| !route.is_empty() && !occupied.contains(route))
+        .filter(|route| seen.insert(route.clone()))
