-// pub fn ffi_native_bridge_serialize_item_stack_impl(
-//     request: SerializeItemStackRequest,
-// ) -> Option<SerializeItemStackResponse> {
-//     Some(())
-// }
+use pumpkin_data::{item::Item, item_stack::ItemStack};
+
+use crate::proto::patchbukkit::itemstack::ItemStack as BridgeItemStack;
+
+const MAX_NATIVE_NBT_BYTES: usize = 1024 * 1024;
+
+pub fn serialize_item_stack(stack: &ItemStack) -> Option<BridgeItemStack> {
+    let has_native_components = !stack.patch.is_empty();
+    let mut normalized = stack.clone();
+    if !normalized.is_empty() {
+        normalized.item_count = 1;
+    }
+
+    Some(BridgeItemStack {
+        r#type: format!("minecraft:{}", stack.item.registry_key),
+        amount: u32::from(stack.item_count),
+        native_nbt: normalized.to_nbt_bytes().ok()?,
+        has_native_components,
+    })
+}
+
+pub fn deserialize_item_stack(stack: BridgeItemStack) -> Option<ItemStack> {
+    let amount = u8::try_from(stack.amount).ok()?;
+    let requested_type = stack
+        .r#type
+        .strip_prefix("minecraft:")
+        .unwrap_or(&stack.r#type);
+
+    if amount == 0 || requested_type == "air" {
+        return Some(ItemStack::EMPTY.clone());
+    }
+
+    if !stack.native_nbt.is_empty() {
+        if stack.native_nbt.len() > MAX_NATIVE_NBT_BYTES {
+            return None;
+        }
+
+        let mut restored = ItemStack::from_nbt_bytes(&stack.native_nbt).ok()??;
+        if restored.item.registry_key != requested_type {
+            return None;
+        }
+        restored.item_count = amount;
+        return Some(restored);
+    }
+
+    Some(ItemStack::new(
+        amount,
+        Item::from_registry_key(requested_type)?,
+    ))
+}
+
+#[cfg(test)]
+mod tests {
+    use pumpkin_data::{
+        data_component::DataComponent,
+        data_component_impl::{DataComponentImpl, UnbreakableImpl},
+        item::Item,
+        item_stack::ItemStack,
+    };
+
+    use super::{deserialize_item_stack, serialize_item_stack};
+
+    #[test]
+    fn bridge_roundtrip_preserves_native_components_and_allows_amount_changes() {
+        let mut native = ItemStack::new(1, &Item::WOODEN_AXE);
+        native
+            .patch
+            .push((DataComponent::Unbreakable, Some(UnbreakableImpl.to_dyn())));
+
+        let mut bridge = serialize_item_stack(&native).expect("item should serialize");
+        bridge.amount = 3;
+        let restored = deserialize_item_stack(bridge).expect("item should restore");
+
+        assert_eq!(restored.item.registry_key, Item::WOODEN_AXE.registry_key);
+        assert_eq!(restored.item_count, 3);
+        assert!(restored.get_data_component::<UnbreakableImpl>().is_some());
+    }
+
+    #[test]
+    fn bridge_rejects_native_snapshot_for_a_different_material() {
+        let native = ItemStack::new(1, &Item::WOODEN_AXE);
+        let mut bridge = serialize_item_stack(&native).expect("item should serialize");
+        bridge.r#type = "minecraft:stone".to_owned();
+
+        assert!(deserialize_item_stack(bridge).is_none());
+    }
+}
