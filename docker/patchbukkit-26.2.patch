+import org.bukkit.Location;
+import org.bukkit.block.Block;
+import org.bukkit.block.BlockState;
+import org.bukkit.metadata.MetadataValue;
+import org.bukkit.plugin.Plugin;
+
+/**
+ * Immutable Bukkit snapshot facade for a block captured before a native event mutation.
+ *
+ * <p>The facade deliberately exposes only snapshot reads that PatchBukkit can answer
+ * without inventing server state. Write methods fail explicitly until Pumpkin exposes
+ * a block-state write contract.</p>
+ */
+public final class PatchBukkitBlockState implements InvocationHandler {
+    private final Block block;
+
+    private PatchBukkitBlockState(Block block) {
+        this.block = Objects.requireNonNull(block, "block");
+    }
+
+    public static BlockState create(Block block) {
+        return (BlockState) Proxy.newProxyInstance(
+            BlockState.class.getClassLoader(),
+            new Class<?>[] { BlockState.class },
+            new PatchBukkitBlockState(block)
+        );
+    }
+
+    @Override
+    @SuppressWarnings("deprecation")
+    public Object invoke(Object proxy, Method method, Object[] arguments) {
+        Object[] args = arguments == null ? new Object[0] : arguments;
+        return switch (method.getName()) {
+            case "getBlock" -> this.block;
+            case "getType" -> this.block.getType();
+            case "getBlockData" -> this.block.getBlockData().clone();
+            case "getData" -> this.block.getType().getNewData((byte) 0);
+            case "getRawData", "getLightLevel" -> (byte) 0;
+            case "getWorld" -> this.block.getWorld();
+            case "getX" -> this.block.getX();
+            case "getY" -> this.block.getY();
+            case "getZ" -> this.block.getZ();
+            case "getLocation" -> getLocation(args);
+            case "isPlaced" -> true;
+            case "hasMetadata" -> this.block.hasMetadata((String) args[0]);
+            case "getMetadata" -> this.block.getMetadata((String) args[0]);
+            case "setMetadata" -> {
+                this.block.setMetadata((String) args[0], (MetadataValue) args[1]);
+                yield null;
+            }
+            case "removeMetadata" -> {
+                this.block.removeMetadata((String) args[0], (Plugin) args[1]);
+                yield null;
+            }
+            case "hashCode" -> Objects.hash(
+                this.block.getWorld().getUID(),
+                this.block.getX(),
+                this.block.getY(),
+                this.block.getZ(),
+                this.block.getType()
+            );
+            case "equals" -> proxy == args[0];
+            case "toString" -> "PatchBukkitBlockState{" + this.block + "}";
+            case "setType", "setBlockData", "setRawData", "update" ->
+                throw unsupported(method);
+            default -> throw unsupported(method);
+        };
+    }
+
+    private Location getLocation(Object[] args) {
+        if (args.length == 0) {
+            return this.block.getLocation();
+        }
+        return this.block.getLocation((Location) args[0]);
+    }
+
+    private static UnsupportedOperationException unsupported(Method method) {
+        return new UnsupportedOperationException(
+            "BlockState method '" + method.getName()
+                + "' requires a native snapshot or write contract that PatchBukkit does not yet expose"
+        );
+    }
+}
