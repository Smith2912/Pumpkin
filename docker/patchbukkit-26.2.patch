+                .map(PLAIN::serialize)
+                .forEach(builder::addLore);
+        }
+        state.enchantments.forEach((enchantment, level) ->
+            builder.putEnchantments(enchantment.getKey().asString(), level)
+        );
+        if (state.damage != null) {
+            builder.setDamage(state.damage);
+        }
+        if (state.repairCost != null) {
+            builder.setRepairCost(state.repairCost);
+        }
+        return builder.build();
+    }
+
+    static ItemMeta copyFor(ItemMeta meta, Material material) {
