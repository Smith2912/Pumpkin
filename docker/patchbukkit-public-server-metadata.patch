diff --git a/java/patchbukkit/src/main/java/org/patchbukkit/metadata/PatchBukkitMetadataStore.java b/java/patchbukkit/src/main/java/org/patchbukkit/metadata/PatchBukkitMetadataStore.java
new file mode 100644
index 0000000000000000000000000000000000000000..b9f45daa55997e53ee55e5eee7b633e03c56390b
--- /dev/null
+++ b/java/patchbukkit/src/main/java/org/patchbukkit/metadata/PatchBukkitMetadataStore.java
@@ -0,0 +1,108 @@
+package org.patchbukkit.metadata;
+
+import java.util.ArrayList;
+import java.util.List;
+import java.util.Objects;
+import java.util.UUID;
+import java.util.concurrent.ConcurrentHashMap;
+import java.util.concurrent.ConcurrentMap;
+import org.bukkit.metadata.MetadataValue;
+import org.bukkit.plugin.Plugin;
+
+/**
+ * Process-local Bukkit metadata with Bukkit's plugin-owner semantics.
+ *
+ * <p>Metadata is runtime-only. Stable target keys make independently-created
+ * Bukkit wrappers observe the same values without persisting values to disk.</p>
+ */
+public final class PatchBukkitMetadataStore {
+    private static final ConcurrentMap<TargetKey, ConcurrentMap<String, List<MetadataValue>>> VALUES =
+        new ConcurrentHashMap<>();
+
+    private PatchBukkitMetadataStore() {}
+
+    public static TargetKey entity(UUID uuid) {
+        return new TargetKey("entity", Objects.requireNonNull(uuid).toString());
+    }
+
+    public static TargetKey world(UUID uuid) {
+        return new TargetKey("world", Objects.requireNonNull(uuid).toString());
+    }
+
+    public static TargetKey block(UUID worldUuid, int x, int y, int z) {
+        return new TargetKey(
+            "block",
+            Objects.requireNonNull(worldUuid) + ":" + x + ":" + y + ":" + z
+        );
+    }
+
+    public static void set(TargetKey target, String key, MetadataValue value) {
+        Objects.requireNonNull(target, "target");
+        Objects.requireNonNull(key, "metadata key");
+        Objects.requireNonNull(value, "metadata value");
+        Objects.requireNonNull(value.getOwningPlugin(), "metadata owning plugin");
+        VALUES.computeIfAbsent(target, ignored -> new ConcurrentHashMap<>())
+            .compute(key, (ignored, existing) -> {
+                List<MetadataValue> replacement = existing == null
+                    ? new ArrayList<>()
+                    : new ArrayList<>(existing);
+                replacement.removeIf(old -> old.getOwningPlugin() == value.getOwningPlugin());
+                replacement.add(value);
+                return List.copyOf(replacement);
+            });
+    }
+
+    public static List<MetadataValue> get(TargetKey target, String key) {
+        ConcurrentMap<String, List<MetadataValue>> targetValues = VALUES.get(target);
+        return targetValues == null ? List.of() : targetValues.getOrDefault(key, List.of());
+    }
+
+    public static boolean has(TargetKey target, String key) {
+        return !get(target, key).isEmpty();
+    }
+
+    public static void remove(TargetKey target, String key, Plugin owner) {
+        Objects.requireNonNull(owner, "metadata owning plugin");
+        ConcurrentMap<String, List<MetadataValue>> targetValues = VALUES.get(target);
+        if (targetValues == null) {
+            return;
+        }
+        targetValues.computeIfPresent(key, (ignored, existing) -> {
+            List<MetadataValue> retained = existing.stream()
+                .filter(value -> value.getOwningPlugin() != owner)
+                .toList();
+            return retained.isEmpty() ? null : retained;
+        });
+        if (targetValues.isEmpty()) {
+            VALUES.remove(target, targetValues);
+        }
+    }
+
+    /** Removes metadata belonging to a plugin when that plugin is disabled. */
+    public static void clearPlugin(Plugin owner) {
+        Objects.requireNonNull(owner, "plugin");
+        VALUES.forEach((target, targetValues) -> {
+            targetValues.forEach((key, ignored) -> targetValues.computeIfPresent(key, (unused, values) -> {
+                List<MetadataValue> retained = values.stream()
+                    .filter(value -> value.getOwningPlugin() != owner)
+                    .toList();
+                return retained.isEmpty() ? null : retained;
+            }));
+            if (targetValues.isEmpty()) {
+                VALUES.remove(target, targetValues);
+            }
+        });
+    }
+
+    /** Clears ephemeral metadata when a player/entity session ends. */
+    public static void clear(TargetKey target) {
+        VALUES.remove(Objects.requireNonNull(target, "target"));
+    }
+
+    public record TargetKey(String type, String value) {
+        public TargetKey {
+            Objects.requireNonNull(type, "type");
+            Objects.requireNonNull(value, "value");
+        }
+    }
+}
